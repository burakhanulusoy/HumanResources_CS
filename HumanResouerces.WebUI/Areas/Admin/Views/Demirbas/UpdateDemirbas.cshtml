@model HumanResources.WebUI.DTOs.DemirbasDtos.UpdateDemirbasDto
@using HumanResouerces.WebUI.Enums
@{
    ViewData["Title"] = "Demirbaş Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <i class="bi bi-pencil-square me-2"></i>Demirbaş Güncelle
            </div>
            <div class="card-body p-4">
                <form id="updateDemirbasForm" asp-action="UpdateDemirbas" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="ZimmetTuruId" class="form-label">Kategori (Zimmet Türü)</label>
                            <select asp-for="ZimmetTuruId" class="form-select js-select2" required>
                                <option value=""></option>
                                @if (ViewBag.ItemTypes != null)
                                {
                                    foreach (var type in ViewBag.ItemTypes)
                                    {
                                        <option value="@type.Id" selected="@(type.Id == Model.ZimmetTuruId)">@type.Ad</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ZimmetTuruId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Durumu" class="form-label">Durum</label>
                            <select asp-for="Durumu" class="form-select" asp-items="Html.GetEnumSelectList<DemirbasDurumu>()"></select>
                            <span asp-validation-for="Durumu" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Marka" class="form-label">Marka</label>
                            <input asp-for="Marka" class="form-control" maxlength="100" required />
                            <span asp-validation-for="Marka" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Model" class="form-label">Model</label>
                            <input asp-for="Model" class="form-control" maxlength="100" required />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SeriNumarasi" class="form-label">Seri Numarası</label>
                        <input asp-for="SeriNumarasi" class="form-control" maxlength="100" />
                        <span asp-validation-for="SeriNumarasi" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Aciklama" class="form-label">Açıklama / Notlar</label>
                        <textarea asp-for="Aciklama" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Aciklama" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                        <button type="submit" class="btn btn-warning px-4">
                            <i class="bi bi-check-lg me-1"></i>Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $('.js-select2').select2({ theme: 'bootstrap-5', width: '100%' });

    const form = document.getElementById('updateDemirbasForm');
    form.addEventListener('submit', function (e) {
        if (form.dataset.confirmed === 'true') return;
        if (!form.checkValidity()) return;
        e.preventDefault();
        Swal.fire({
            title: 'Değişiklikler kaydedilsin mi?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Evet, güncelle',
            cancelButtonText: 'İptal'
        }).then(function (result) {
            if (result.isConfirmed) { form.dataset.confirmed = 'true'; form.submit(); }
        });
    });
</script>