@model List<HumanResources.WebUI.DTOs.EducationDtos.EducationDto>
@using HumanResouerces.WebUI.Enums

@{
    ViewData["Title"] = "Eğitimler";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0"><i class="bi bi-mortarboard me-2"></i>Eğitim Yönetimi</h3>
    <a asp-action="CreateEducation" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Yeni Eğitim
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Eğitim</th>
                    <th>Eğitmen</th>
                    <th>Tarih</th>
                    <th class="text-center">Süre</th>
                    <th class="text-center">Durum</th>
                    <th class="text-center">Katılımcı</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var egitim in Model)
                {
                    <tr>
                        <td class="fw-semibold">@egitim.Ad</td>
                        <td>@egitim.Egitmen</td>
                        <td>@egitim.EgitimTarihi.ToString("dd.MM.yyyy")</td>
                        <td class="text-center">@egitim.SuresiSaat saat</td>
                        <td class="text-center">
                            @switch (egitim.Durumu)
                            {
                                case TrainingStatus.Planlandi:
                                    <span class="badge bg-info">Planlandı</span>
                                    break;
                                case TrainingStatus.DevamEdiyor:
                                    <span class="badge bg-warning text-dark">Devam Ediyor</span>
                                    break;
                                case TrainingStatus.Tamamlandi:
                                    <span class="badge bg-success">Tamamlandı</span>
                                    break;
                                case TrainingStatus.IptalEdildi:
                                    <span class="badge bg-danger">İptal</span>
                                    break;
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge rounded-pill bg-secondary">@egitim.Katilimcilar.Count kişi</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="DetailsEducation" asp-route-id="@egitim.Id" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="UpdateEducation" asp-route-id="@egitim.Id" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="DeleteEducation" asp-route-id="@egitim.Id" method="post"
                                  class="d-inline js-delete-form">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // 1) Silme onayı
    document.querySelectorAll('.js-delete-form').forEach(function (form) {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            Swal.fire({
                title: 'Emin misiniz?',
                text: 'Bu eğitim kalıcı olarak silinecek.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, sil',
                cancelButtonText: 'Vazgeç',
                confirmButtonColor: '#d33'
            }).then(function (result) {
                if (result.isConfirmed) form.submit();
            });
        });
    });

    // 2) Create/Update/Delete sonrası başarı mesajı (query string üzerinden)
    (function () {
        const params = new URLSearchParams(window.location.search);
        const basarili = params.get('basarili');

        const mesajlar = {
            olusturuldu: 'Eğitim başarıyla oluşturuldu.',
            guncellendi: 'Eğitim başarıyla güncellendi.',
            silindi: 'Eğitim başarıyla silindi.'
        };

        if (basarili && mesajlar[basarili]) {
            Swal.fire({
                icon: 'success',
                title: mesajlar[basarili],
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2200,
                timerProgressBar: true
            });

            // URL'i temizle (F5'te tekrar göstermesin)
            params.delete('basarili');
            const yeniUrl = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
            window.history.replaceState({}, '', yeniUrl);
        }
    })();
</script>