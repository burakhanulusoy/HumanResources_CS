@model HumanResources.WebUI.DTOs.EducationDtos.UpdateEducationDto
@using HumanResouerces.WebUI.Enums
@{
    ViewData["Title"] = "Eğitim Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <i class="bi bi-pencil-square me-2"></i>Eğitimi Güncelle
            </div>
            <div class="card-body">
                <form asp-action="UpdateEducation" method="post" id="updateEducationForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Ad" class="form-label">Eğitim Adı</label>
                        <input asp-for="Ad" class="form-control" />
                        <span asp-validation-for="Ad" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Egitmen" class="form-label">Eğitmen</label>
                        <input asp-for="Egitmen" class="form-control" />
                        <span asp-validation-for="Egitmen" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EgitimAciklamasi" class="form-label">Açıklama</label>
                        <textarea asp-for="EgitimAciklamasi" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="EgitimAciklamasi" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label asp-for="EgitimTarihi" class="form-label">Tarih</label>
                            <input asp-for="EgitimTarihi" type="date" class="form-control" />
                            <span asp-validation-for="EgitimTarihi" class="text-danger small"></span>
                        </div>
                        <div class="col-6 mb-3">
                            <label asp-for="SuresiSaat" class="form-label">Süre (Saat)</label>
                            <input asp-for="SuresiSaat" type="number" min="1" class="form-control" />
                            <span asp-validation-for="SuresiSaat" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Durumu" class="form-label">Durum</label>
                        <select asp-for="Durumu" class="form-select"
                                asp-items="Html.GetEnumSelectList<TrainingStatus>()"></select>
                        <span asp-validation-for="Durumu" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-check-lg me-1"></i>Güncelle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const form = document.getElementById('updateEducationForm');
    form.addEventListener('submit', function (e) {
        if (form.dataset.confirmed === 'true') return;

        e.preventDefault();
        Swal.fire({
            title: 'Değişiklikler kaydedilsin mi?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Evet, güncelle',
            cancelButtonText: 'Vazgeç'
        }).then(function (result) {
            if (result.isConfirmed) {
                form.dataset.confirmed = 'true';
                form.submit();
            }
        });
    });
</script>