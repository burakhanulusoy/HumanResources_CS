@model List<HumanResources.WebUI.DTOs.CertificateDtos.CertificateDto>
@using HumanResouerces.WebUI.Enums
@{
    ViewData["Title"] = "Dikkat Gerektiren Sertifikalar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center">
        <h3 class="mb-0 me-3"><i class="bi bi-exclamation-octagon text-danger me-2"></i>Dikkat Gerektiren Sertifikalar</h3>
        <span class="badge bg-danger text-white fs-6">@Model.Count kayıt</span>
    </div>

    <div class="input-group" style="max-width: 300px;">
        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
        <input type="text" id="searchInput" class="form-control" placeholder="Personel adına göre ara...">
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (Model.Count > 0)
        {
            <table class="table table-hover align-middle mb-0" id="certificateTable">
                <thead class="table-light">
                    <tr>
                        <th>Personel</th>
                        <th>Sertifika Türü</th>
                        <th>Geçerlilik Tarihi</th>
                        <th class="text-center">Durum / Kalan Gün</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        var kalanGun = (s.GecerlilikTarihi.Date - DateTime.Today).Days;
                        string rowClass = "";

                        // Duruma göre satır rengini (arka planı) belirliyoruz
                        if (s.Durumu == CertificateStatus.IptalEdildi)
                            rowClass = "table-secondary text-muted";
                        else if (s.Durumu == CertificateStatus.SuresiDolu || kalanGun < 0)
                            rowClass = "table-danger";
                        else if (kalanGun <= 7)
                            rowClass = "table-warning";

                        <tr class="@rowClass">
                            <td class="fw-semibold text-nowrap personel-name">@s.AppUser?.Ad @s.AppUser?.Soyad</td>
                            <td>@s.SertifikaTuru?.Ad</td>
                            <td class="text-nowrap">@s.GecerlilikTarihi.ToString("dd.MM.yyyy")</td>
                            <td class="text-center">
                                @if (s.Durumu == CertificateStatus.IptalEdildi)
                                {
                                    <span class="badge bg-dark">İptal Edildi</span>
                                }
                                else if (s.Durumu == CertificateStatus.SuresiDolu || kalanGun < 0)
                                {
                                    <span class="badge bg-danger">
                                        @(kalanGun < 0 ? $"{-kalanGun} gün önce doldu" : "Süresi Doldu")
                                    </span>
                                }
                                else if (kalanGun == 0)
                                {
                                    <span class="badge bg-danger">Bugün doluyor</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@kalanGun gün kaldı</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="DetailsCertificate" asp-route-id="@s.Id" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye"></i> İncele
                                </a>
                                <a asp-action="UpdateCertificate" asp-route-id="@s.Id" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-arrow-repeat"></i> Yenile
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div id="noResultMessage" class="text-center text-muted py-4" style="display: none;">
                <i class="bi bi-search fs-2 d-block mb-2"></i>
                Aradığınız kritere uygun personel bulunamadı.
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-check-circle fs-1 d-block mb-2 text-success"></i>
                İşlem bekleyen (süresi yaklaşan, dolan veya iptal edilen) sertifika bulunmuyor.
            </div>
        }
    </div>
</div>

<script>
    // Arama (Filtreleme) Scripti
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("searchInput");
        const noResultMessage = document.getElementById("noResultMessage");

        if (searchInput) {
            searchInput.addEventListener("keyup", function () {
                const filter = this.value.toLowerCase();
                const rows = document.querySelectorAll("#certificateTable tbody tr");
                let hasVisibleRow = false;

                rows.forEach(row => {
                    const text = row.querySelector(".personel-name").textContent.toLowerCase();
                    if (text.includes(filter)) {
                        row.style.display = "";
                        hasVisibleRow = true;
                    } else {
                        row.style.display = "none";
                    }
                });

                if (noResultMessage) {
                    noResultMessage.style.display = hasVisibleRow ? "none" : "block";
                }
            });
        }
    });
</script>