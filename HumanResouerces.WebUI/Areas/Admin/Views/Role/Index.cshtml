@model List<HumanResources.WebUI.DTOs.RoleDtos.ResultRoleDto>
@{
    ViewData["Title"] = "Rol Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int roleCount = Model?.Count ?? 0;
}

<style>
    :root {
        --navy: #0B2545;
        --navy-2: #143A6B;
        --cyan: #29A8CC;
        --cyan-2: #4FC3E0;
        --cyan-soft: #EAF6FA;
        --ink: #1F2A37;
        --muted: #64748B;
        --line: #E7ECF3;
        --soft: #F7F9FC;
    }

    .role-page svg {
        display: block;
    }

    .role-toolbar {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 18px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 24px;
        box-shadow: 0 1px 3px rgba(16,24,40,.04);
    }

        .role-toolbar .title-wrap {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .role-toolbar .icon-wrap {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            background: linear-gradient(140deg, var(--navy), var(--navy-2));
            color: var(--cyan);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .role-toolbar h5 {
            margin: 0;
            font-weight: 700;
            color: var(--navy);
            font-size: 1.15rem;
        }

        .role-toolbar .meta {
            font-size: .82rem;
            color: var(--muted);
            margin-top: 3px;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
        }

        .role-toolbar .count-chip {
            background: var(--cyan-soft);
            color: var(--navy);
            font-weight: 700;
            border-radius: 999px;
            padding: .1rem .55rem;
            font-size: .78rem;
        }

    .btn-new-role {
        background: var(--navy);
        color: #fff;
        border: none;
        font-weight: 600;
        border-radius: 11px;
        padding: .6rem 1.25rem;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        box-shadow: 0 6px 16px rgba(11,37,69,.25);
        transition: all .15s ease;
        text-decoration: none;
    }

        .btn-new-role:hover {
            background: #0d2c55;
            color: #fff;
            transform: translateY(-1px);
        }

        .btn-new-role svg {
            color: var(--cyan);
        }

    .role-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
    }

    .role-card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 0;
        box-shadow: 0 2px 10px rgba(16,24,40,.05);
        display: flex;
        flex-direction: column;
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
        position: relative;
        overflow: hidden;
    }

        .role-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 30px rgba(11,37,69,.14);
            border-color: #d7e0ec;
        }

        .role-card .card-top {
            padding: 22px 22px 16px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

    .role-avatar {
        width: 54px;
        height: 54px;
        border-radius: 15px;
        flex-shrink: 0;
        background: linear-gradient(140deg, var(--navy), var(--cyan));
        color: #fff;
        font-weight: 800;
        font-size: 1.35rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        letter-spacing: .5px;
        box-shadow: 0 6px 14px rgba(11,37,69,.22);
    }

    .role-meta .role-name {
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--navy);
        line-height: 1.2;
        word-break: break-word;
    }

    .role-meta .role-id {
        font-size: .72rem;
        color: var(--muted);
        margin-top: 4px;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        background: var(--soft);
        padding: .12rem .5rem;
        border-radius: 6px;
        border: 1px solid var(--line);
    }

    .role-divider {
        height: 1px;
        background: var(--line);
        margin: 0 22px;
    }

    .role-actions {
        display: flex;
        gap: 8px;
        padding: 14px 22px 20px;
        margin-top: auto;
    }

    .btn-inspect {
        flex: 1;
        background: var(--cyan-soft);
        color: var(--navy);
        border: 1px solid rgba(41,168,204,.28);
        border-radius: 11px;
        font-size: .85rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        padding: .55rem .5rem;
        transition: all .15s ease;
        cursor: pointer;
        text-decoration: none;
    }

        .btn-inspect:hover {
            background: #d7edf5;
            color: var(--navy);
        }

    .icon-btn {
        width: 42px;
        height: 42px;
        border-radius: 11px;
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line);
        background: var(--soft);
        cursor: pointer;
        transition: all .15s ease;
        text-decoration: none;
    }

        .icon-btn.edit {
            color: var(--navy-2);
        }

            .icon-btn.edit:hover {
                background: #eaeff6;
                border-color: #cfd9e6;
                color: var(--navy);
            }

        .icon-btn.del {
            color: #d14343;
            background: #fff5f5;
            border-color: #f4d7d7;
        }

            .icon-btn.del:hover {
                background: #ffe6e6;
                border-color: #eec0c0;
                color: #b02f2f;
            }

    .role-empty {
        grid-column: 1 / -1;
        text-align: center;
        padding: 4rem 1rem;
        color: #9aa5b4;
        background: #fff;
        border: 1.5px dashed var(--line);
        border-radius: 18px;
    }

        .role-empty .empty-ic {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            margin: 0 auto 1rem;
            background: var(--soft);
            color: #c3cdda;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

    .btn-soft {
        background: var(--soft);
        border: 1px solid var(--line);
        color: #475569;
        border-radius: 10px;
        font-weight: 600;
    }
</style>

<div class="role-page">
    <div class="role-toolbar">
        <div class="title-wrap">
            <span class="icon-wrap">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path d="m9 12 2 2 4-4" /></svg>
            </span>
            <div>
                <h5>Rol Yönetimi</h5>
                <div class="meta">Sistemde <span class="count-chip">@roleCount</span> rol tanımlı</div>
            </div>
        </div>
        <a class="btn-new-role" asp-area="Admin" asp-controller="Role" asp-action="CreateRole">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            Yeni Rol
        </a>
    </div>

    <div class="role-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var role in Model)
            {
                string harf = string.IsNullOrEmpty(role.Name) ? "?" : role.Name.Trim().Substring(0, 1).ToUpper();
                <div class="role-card">
                    <div class="card-top">
                        <span class="role-avatar">@harf</span>
                        <div class="role-meta">
                            <div class="role-name">@role.Name</div>
                            <span class="role-id">Rol No · #@role.Id</span>
                        </div>
                    </div>
                    <div class="role-divider"></div>
                    <div class="role-actions">
                        <a class="btn-inspect" asp-area="Admin" asp-controller="Role" asp-action="RoleUsers" asp-route-roleName="@role.Name">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                            İncele
                        </a>
                        <a class="icon-btn edit" asp-area="Admin" asp-controller="Role" asp-action="UpdateRole" asp-route-id="@role.Id" title="Düzenle">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z" /></svg>
                        </a>
                        <button type="button" class="icon-btn del js-del-role" data-id="@role.Id" data-name="@role.Name" title="Sil">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6" /><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /><line x1="10" y1="11" x2="10" y2="17" /><line x1="14" y1="11" x2="14" y2="17" /></svg>
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="role-empty">
                <span class="empty-ic">
                    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><line x1="4" y1="4" x2="20" y2="20" /></svg>
                </span>
                <p class="mb-0">Henüz tanımlı bir rol bulunmuyor. "Yeni Rol" ile ekleyebilirsin.</p>
            </div>
        }
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border:none;border-radius:.9rem;overflow:hidden;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-danger d-inline-flex align-items-center gap-2">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                    Rolü Sil
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <span id="deleteRoleText">Bu rolü silmek istediğinize emin misiniz?</span>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-soft" data-bs-dismiss="modal">Vazgeç</button>
                <a id="deleteRoleConfirm" class="btn btn-danger">Evet, Sil</a>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        document.querySelectorAll('.js-del-role').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.getElementById('deleteRoleText').innerHTML =
                    '<strong>' + btn.dataset.name + '</strong> rolünü silmek istediğinize emin misiniz? Bu işlem geri alınamaz.';
                document.getElementById('deleteRoleConfirm').href =
                    '/Admin/Role/DeleteRole/' + btn.dataset.id;
                new bootstrap.Modal(document.getElementById('deleteRoleModal')).show();
            });
        });
    })();
</script>
