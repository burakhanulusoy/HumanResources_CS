@model List<HumanResources.WebUI.DTOs.ItemDtos.ItemDto>
@{
    ViewData["Title"] = "Zimmet Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0"><i class="bi bi-box-seam me-2"></i>Zimmet Yönetimi</h3>
    <div class="d-flex gap-3">
        <div class="input-group" style="max-width: 260px;">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input type="text" id="searchInput" class="form-control" placeholder="Personel adına göre ara...">
        </div>
        <a asp-action="CreateItem" class="btn btn-primary text-nowrap">
            <i class="bi bi-plus-lg me-1"></i>Yeni Zimmet Ver
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0" id="itemTable">
            <thead class="table-light">
                <tr>
                    <th>Personel</th>
                    <th>Zimmet Türü</th>
                    <th>Marka / Model</th>
                    <th>Seri No</th>
                    <th>Teslim Tarihi</th>
                    <th class="text-center">Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td class="fw-semibold text-nowrap personel-name">@item.AppUser?.Ad @item.AppUser?.Soyad</td>
                            <td>@item.ZimmetTuru?.Ad</td>
                            <td class="text-muted">
                                @(string.IsNullOrEmpty(item.Marka) && string.IsNullOrEmpty(item.Model)
                                                        ? "-"
                                                        : $"{item.Marka} {item.Model}")
                    </td>
                    <td><span class="text-muted">@(string.IsNullOrEmpty(item.SeriNumarasi) ? "-" : item.SeriNumarasi)</span></td>
                    <td class="text-nowrap">@item.TeslimTarihi.ToString("dd.MM.yyyy")</td>
                    <td class="text-center">
                        @switch (item.Durumu.ToString())
                                {
                                    case "Aktif":
                                        <span class="badge bg-success">Aktif</span>
                                        break;
                                    case "IadeEdildi":
                                        <span class="badge bg-secondary">İade Edildi</span>
                                        break;
                                    case "Arizali":
                                        <span class="badge bg-warning text-dark">Arızalı</span>
                                        break;
                                    case "Kayip":
                                        <span class="badge bg-danger">Kayıp</span>
                                        break;
                                    default:
                                        <span class="badge bg-light text-dark">@item.Durumu</span>
                                        break;
                                }
                            </td>
                            <td class="text-end" style="min-width: 190px; white-space: nowrap;">
                                <a asp-action="ItemDetails" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="İncele">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="UpdateItem" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Düzenle">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="ZimmetBelgesi" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Teslim Belgesi">
                                    <i class="bi bi-file-earmark-text"></i>
                                </a>
                                <form asp-action="DeleteItem" asp-route-id="@item.Id" method="get" class="d-inline js-delete-form">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                Henüz sisteme eklenmiş bir zimmet bulunmuyor.
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div id="noResultMessage" class="text-center text-muted py-4" style="display: none;">
            <i class="bi bi-search fs-2 d-block mb-2"></i>
            Aradığınız kritere uygun personel bulunamadı.
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.querySelectorAll('.js-delete-form').forEach(function (form) {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            Swal.fire({
                title: 'Emin misiniz?',
                text: 'Bu zimmet kaydı kalıcı olarak silinecek.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, sil',
                cancelButtonText: 'Vazgeç',
                confirmButtonColor: '#d33'
            }).then(function (result) {
                if (result.isConfirmed) form.submit();
            });
        });
    });

    // Arama (Filtreleme) Scripti
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("searchInput");
        const noResultMessage = document.getElementById("noResultMessage");

        if (searchInput) {
            searchInput.addEventListener("keyup", function () {
                const filter = this.value.toLowerCase();
                const rows = document.querySelectorAll("#itemTable tbody tr");
                let hasVisibleRow = false;

                rows.forEach(row => {
                    const nameCell = row.querySelector(".personel-name");
                    if (!nameCell) return; // boş satır (kayıt yok mesajı) atlanır
                    const text = nameCell.textContent.toLowerCase();
                    if (text.includes(filter)) {
                        row.style.display = "";
                        hasVisibleRow = true;
                    } else {
                        row.style.display = "none";
                    }
                });

                if (noResultMessage) {
                    noResultMessage.style.display = hasVisibleRow ? "none" : "block";
                }
            });
        }
    });
</script>
