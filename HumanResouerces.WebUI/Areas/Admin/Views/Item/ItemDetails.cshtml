@model HumanResources.WebUI.DTOs.ItemDtos.ItemDto
@{
    ViewData["Title"] = "Zimmet Detayları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0"><i class="bi bi-box-seam me-2"></i>Zimmet Detayı</h3>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Listeye Dön
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-info-circle me-2"></i>Zimmet Bilgileri</span>
                @switch (Model.Durumu.ToString())
                {
                    case "Aktif":
                        <span class="badge bg-success px-3">Aktif</span>
                        break;
                    case "IadeEdildi":
                        <span class="badge bg-secondary px-3">İade Edildi</span>
                        break;
                    case "Arizali":
                        <span class="badge bg-warning text-dark px-3">Arızalı</span>
                        break;
                    case "Kayip":
                        <span class="badge bg-danger px-3">Kayıp</span>
                        break;
                }
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded h-100">
                            <div class="text-muted small mb-1"><i class="bi bi-tags me-1"></i>Zimmet Türü</div>
                            <div class="fw-semibold">@(Model.Demirbas?.ZimmetTuru?.Ad ?? "-")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded h-100">
                            <div class="text-muted small mb-1"><i class="bi bi-upc-scan me-1"></i>Seri Numarası</div>
                            <div class="fw-semibold">@(string.IsNullOrEmpty(Model.Demirbas?.SeriNumarasi) ? "Belirtilmemiş" : Model.Demirbas.SeriNumarasi)</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded h-100">
                            <div class="text-muted small mb-1"><i class="bi bi-award me-1"></i>Marka</div>
                            <div class="fw-semibold">@(string.IsNullOrEmpty(Model.Demirbas?.Marka) ? "-" : Model.Demirbas.Marka)</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded h-100">
                            <div class="text-muted small mb-1"><i class="bi bi-cpu me-1"></i>Model</div>
                            <div class="fw-semibold">@(string.IsNullOrEmpty(Model.Demirbas?.Model) ? "-" : Model.Demirbas.Model)</div>
                        </div>
                    </div>
                </div>

                <div class="row text-center mt-4">
                    <div class="col-6">
                        <div class="border-end">
                            <div class="text-muted small">Teslim Tarihi</div>
                            <div class="fw-bold fs-6"><i class="bi bi-calendar-check text-primary me-1"></i>@Model.TeslimTarihi.ToString("dd.MM.yyyy")</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small">İade Tarihi</div>
                        <div class="fw-bold fs-6">
                            @if (Model.SuresizMi)
                            {
                                <i class="bi bi-infinity text-info me-1"></i>
                                <span>Süresiz</span>
                            }
                            else if (Model.IadeTarihi.HasValue && Model.IadeTarihi.Value.Year > 2000)
                            {
                                <i class="bi bi-calendar-x text-secondary me-1"></i>
                                @Model.IadeTarihi.Value.ToString("dd.MM.yyyy")
                            }
                            else
                            {
                                <i class="bi bi-hourglass-split text-secondary me-1"></i>
                                <span>Devam Ediyor</span>
                            }
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="text-muted small mb-1"><i class="bi bi-chat-left-text me-1"></i>Açıklama / Notlar</div>
                <div class="p-3 bg-light rounded">
                    @(string.IsNullOrEmpty(Model.Aciklama) ? "Bu zimmet ile ilgili ek bir açıklama bulunmamaktadır." : Model.Aciklama)
                </div>
            </div>
            <div class="card-footer bg-transparent d-flex justify-content-end gap-2">
                <a asp-action="ZimmetBelgesi" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                    <i class="bi bi-file-earmark-text me-1"></i>Teslim Belgesini Görüntüle
                </a>
                <a asp-action="UpdateItem" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i>Düzenle
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <i class="bi bi-person-badge me-2"></i>Zimmetli Personel
            </div>
            <div class="card-body text-center">
                <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center mb-3 shadow-sm"
                     style="width:90px;height:90px;font-size:1.8rem;">
                    @(Model.AppUser?.Ad?.Substring(0, 1))@(Model.AppUser?.Soyad?.Substring(0, 1))
                </div>
                <h5 class="mb-1">@Model.AppUser?.Ad @Model.AppUser?.Soyad</h5>
                <p class="text-muted mb-3">@(Model.AppUser?.DepartmanAd ?? "-") / @(Model.AppUser?.BirimAd ?? "-")</p>

                <a asp-controller="User" asp-action="Details" asp-route-id="@Model.AppUserId"
                   class="btn btn-outline-primary w-100">
                    <i class="bi bi-person-lines-fill me-1"></i>Personeli İncele
                </a>
            </div>
        </div>
    </div>
</div>