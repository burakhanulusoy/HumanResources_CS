@model HumanResources.WebUI.DTOs.ItemDtos.UpdateItemDto
@using HumanResouerces.WebUI.Enums
@{
    ViewData["Title"] = "Zimmet Kaydı Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <i class="bi bi-pencil-square me-2"></i>Zimmeti Güncelle
            </div>
            <div class="card-body p-4">
                <form id="updateItemForm" asp-action="UpdateItem" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="AppUserId" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Personel <small class="text-muted">(değiştirilemez)</small></label>
                            <select class="form-select bg-light text-muted" disabled>
                                @if (ViewBag.Users != null)
                                {
                                    foreach (var user in ViewBag.Users)
                                    {
                                        <option selected="@(user.Id == Model.AppUserId)">@user.Ad @user.Soyad</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DemirbasId" class="form-label">Demirbaş</label>
                            <select asp-for="DemirbasId" class="form-select js-select2" required>
                                <option value=""></option>
                                @if (ViewBag.Demirbaslar != null)
                                {
                                    foreach (var d in ViewBag.Demirbaslar)
                                    {
                                        <option value="@d.Id" selected="@(d.Id == Model.DemirbasId)">
                                            @d.Marka @d.Model @(string.IsNullOrEmpty(d.SeriNumarasi) ? "" : " — " + d.SeriNumarasi)
                                        </option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="DemirbasId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Durumu" class="form-label">Zimmet Durumu</label>
                            <select asp-for="Durumu" class="form-select" asp-items="Html.GetEnumSelectList<ZimmetDurumu>()"></select>
                            <span asp-validation-for="Durumu" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="TeslimTarihi" class="form-label">Teslim Tarihi</label>
                            <input asp-for="TeslimTarihi" type="date" class="form-control" />
                            <span asp-validation-for="TeslimTarihi" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="IadeTarihi" class="form-label">İade Tarihi</label>
                            <input asp-for="IadeTarihi" id="IadeTarihi" type="date" class="form-control" />
                            <span asp-validation-for="IadeTarihi" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" asp-for="SuresizMi" id="SuresizMi" />
                        <label class="form-check-label" for="SuresizMi">
                            <i class="bi bi-infinity me-1"></i>Süresiz zimmet (iade tarihi yok)
                        </label>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Aciklama" class="form-label">Açıklama / Notlar</label>
                        <textarea asp-for="Aciklama" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Aciklama" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                        <button type="submit" class="btn btn-warning px-4">
                            <i class="bi bi-check-lg me-1"></i>Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $('.js-select2').select2({ theme: 'bootstrap-5', width: '100%' });

    const suresiz = document.getElementById('SuresizMi');
    const iade = document.getElementById('IadeTarihi');
    function syncIade() {
        if (suresiz.checked) {
            iade.value = '';
            iade.disabled = true;
            iade.required = false;
        } else {
            iade.disabled = false;
            iade.required = true;
        }
    }
    suresiz.addEventListener('change', syncIade);
    syncIade();

    const form = document.getElementById('updateItemForm');
    form.addEventListener('submit', function (e) {
        if (form.dataset.confirmed === 'true') return;
        if (!form.checkValidity()) return;
        e.preventDefault();
        Swal.fire({
            title: 'Değişiklikler kaydedilsin mi?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Evet, güncelle',
            cancelButtonText: 'İptal'
        }).then(function (result) {
            if (result.isConfirmed) { form.dataset.confirmed = 'true'; form.submit(); }
        });
    });
</script>