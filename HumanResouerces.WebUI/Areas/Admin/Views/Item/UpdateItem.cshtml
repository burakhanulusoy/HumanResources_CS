@model HumanResources.WebUI.DTOs.ItemDtos.UpdateItemDto
@using HumanResouerces.WebUI.Enums
@{
    ViewData["Title"] = "Zimmet Kaydı Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-3 mt-4">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-bold text-dark">Zimmet Kaydı Güncelle</h5>
            </div>
            <div class="card-body p-4">
                <form id="updateItemForm" asp-action="UpdateItem" method="post">

                    <!-- ID ve Değiştirilemeyecek Alanları Gizli Olarak Tutuyoruz -->
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="AppUserId" />
                    <input type="hidden" asp-for="ZimmetTuruId" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary small text-uppercase">Personel (Değiştirilemez)</label>
                            <!-- select alanına "disabled" ekledik ve arkasını hafif kararttık -->
                            <select asp-for="AppUserId" class="form-select form-select-lg bg-secondary bg-opacity-10 text-muted" disabled>
                                @if (ViewBag.Users != null)
                                {
                                    foreach (var user in ViewBag.Users)
                                    {
                                        <option value="@user.Id">@user.Ad @user.Soyad</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary small text-uppercase">Zimmet Türü (Değiştirilemez)</label>
                            <!-- select alanına "disabled" ekledik -->
                            <select asp-for="ZimmetTuruId" class="form-select form-select-lg bg-secondary bg-opacity-10 text-muted" disabled>
                                @if (ViewBag.ItemTypes != null)
                                {
                                    foreach (var type in ViewBag.ItemTypes)
                                    {
                                        <option value="@type.Id">@type.Ad</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SeriNumarasi" class="form-label fw-semibold text-secondary small text-uppercase">Seri Numarası</label>
                            <input asp-for="SeriNumarasi" class="form-control form-control-lg bg-light" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Durumu" class="form-label fw-semibold text-secondary small text-uppercase">Zimmet Durumu <span class="text-danger">*</span></label>
                            <select asp-for="Durumu" class="form-select form-select-lg bg-light" asp-items="Html.GetEnumSelectList<ZimmetDurumu>()"></select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TeslimTarihi" class="form-label fw-semibold text-secondary small text-uppercase">Teslim Tarihi</label>
                            <input asp-for="TeslimTarihi" type="date" class="form-control form-control-lg bg-light" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="IadeTarihi" class="form-label fw-semibold text-secondary small text-uppercase">İade Tarihi</label>
                            <input asp-for="IadeTarihi" type="date" class="form-control form-control-lg bg-light" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Aciklama" class="form-label fw-semibold text-secondary small text-uppercase">Açıklama / Notlar</label>
                            <textarea asp-for="Aciklama" class="form-control bg-light" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a href="/Admin/Item/Index" class="btn btn-light px-4 border">İptal Et</a>
                        <button type="submit" class="btn btn-primary px-4">Değişiklikleri Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.getElementById('updateItemForm').addEventListener('submit', function (e) {
        e.preventDefault();
        Swal.fire({
            title: 'Değişiklikleri Kaydet',
            text: "Zimmet bilgisini güncellemek istediğinize emin misiniz?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#0d6efd',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Evet, Güncelle',
            cancelButtonText: 'İptal'
        }).then((result) => {
            if (result.isConfirmed) this.submit();
        });
    });
</script>