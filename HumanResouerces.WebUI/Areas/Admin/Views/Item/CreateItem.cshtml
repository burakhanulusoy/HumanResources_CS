@model HumanResources.WebUI.DTOs.ItemDtos.CreateItemDto
@{
    ViewData["Title"] = "Yeni Zimmet Ver";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-box-seam me-2"></i>Yeni Zimmet Teslimi
            </div>
            <div class="card-body p-4">
                <form id="createItemForm" asp-action="CreateItem" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                    <h6 class="text-muted border-bottom pb-2 mb-3">Personel ve Demirbaş Seçimi</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="AppUserId" class="form-label">Personel</label>
                            <select asp-for="AppUserId" class="form-select js-select2" required data-placeholder="Personel ara ve seç...">
                                <option value=""></option>
                                @if (ViewBag.Users != null)
                                {
                                    foreach (var user in ViewBag.Users)
                                    {
                                        <option value="@user.Id">@user.Ad @user.Soyad — @user.SicilNo</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="AppUserId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DemirbasId" class="form-label">Demirbaş <small class="text-muted">(sadece müsait olanlar)</small></label>
                            <select asp-for="DemirbasId" class="form-select js-select2" required data-placeholder="Demirbaş ara ve seç...">
                                <option value=""></option>
                                @if (ViewBag.Demirbaslar != null)
                                {
                                    foreach (var d in ViewBag.Demirbaslar)
                                    {
                                        <option value="@d.Id">
                                            @d.Marka @d.Model @(string.IsNullOrEmpty(d.SeriNumarasi) ? "" : " — " + d.SeriNumarasi)
                                        </option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="DemirbasId" class="text-danger small"></span>
                        </div>
                    </div>

                    <h6 class="text-muted border-bottom pb-2 mb-3 mt-2">Teslim Bilgileri</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="TeslimTarihi" class="form-label">Teslim Tarihi</label>
                            <input asp-for="TeslimTarihi" type="date" class="form-control"
                                   max="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                            <span asp-validation-for="TeslimTarihi" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="IadeTarihi" class="form-label">Planlanan İade Tarihi</label>
                            <input asp-for="IadeTarihi" id="IadeTarihi" type="date" class="form-control" />
                            <span asp-validation-for="IadeTarihi" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" asp-for="SuresizMi" id="SuresizMi" />
                        <label class="form-check-label" for="SuresizMi">
                            <i class="bi bi-infinity me-1"></i>Süresiz zimmet (iade tarihi yok, personel kalıcı kullanır)
                        </label>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Aciklama" class="form-label">Açıklama / Notlar</label>
                        <textarea asp-for="Aciklama" class="form-control" rows="3"
                                  placeholder="Teslim edilen eşyanın durumu, çizik/hasar var mı vs."></textarea>
                        <span asp-validation-for="Aciklama" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i>Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $('.js-select2').select2({
        theme: 'bootstrap-5',
        width: '100%',
        language: { noResults: function () { return "Sonuç bulunamadı"; } }
    });

    // --- Süresiz mantığı ---
    const suresiz = document.getElementById('SuresizMi');
    const iade = document.getElementById('IadeTarihi');

    function syncIade() {
        if (suresiz.checked) {
            iade.value = '';
            iade.disabled = true;
            iade.required = false;
        } else {
            iade.disabled = false;
            iade.required = true;
        }
    }
    suresiz.addEventListener('change', syncIade);
    syncIade(); // ilk yüklemede durumu ayarla

    const form = document.getElementById('createItemForm');
    form.addEventListener('submit', function (e) {
        // disabled input post edilmez; süresizken IadeTarihi'nin null gitmesi zaten istediğimiz şey.
        if (form.dataset.confirmed === 'true') return;
        if (!form.checkValidity()) return;
        e.preventDefault();
        Swal.fire({
            title: 'Zimmet kaydedilsin mi?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Evet, kaydet',
            cancelButtonText: 'Vazgeç'
        }).then(function (result) {
            if (result.isConfirmed) { form.dataset.confirmed = 'true'; form.submit(); }
        });
    });
</script>