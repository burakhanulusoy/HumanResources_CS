@model List<HumanResources.WebUI.DTOs.CertificateTypeDtos.ResultCertificateTypeDto>
@{
    ViewData["Title"] = "Sertifika Türleri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<style>
    .ct-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(16, 24, 40, .06);
        overflow: hidden;
    }

    .ct-header {
        background: #fff;
        border-bottom: 1px solid #eef0f3;
        padding: 1.25rem 1.5rem;
    }

    .ct-title {
        font-weight: 700;
        color: #1f2937;
        margin: 0;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

        .ct-title .icon-wrap {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
        }

    .ct-subtitle {
        font-size: .82rem;
        color: #6b7280;
        margin: 2px 0 0;
    }

    .ct-count {
        background: #eef2ff;
        color: #4f46e5;
        font-weight: 600;
        font-size: .78rem;
        border-radius: 999px;
        padding: .3rem .75rem;
    }

    .btn-add {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        border: none;
        color: #fff;
        border-radius: 10px;
        padding: .55rem 1.1rem;
        font-weight: 600;
        transition: transform .15s ease, box-shadow .15s ease;
    }

        .btn-add:hover {
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(34, 197, 94, .35);
        }

    .ct-search {
        max-width: 280px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        padding-left: 2.4rem;
        background: #f9fafb;
    }

        .ct-search:focus {
            background: #fff;
            border-color: #a5b4fc;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, .15);
        }

    .search-wrap {
        position: relative;
    }

        .search-wrap .bi-search {
            position: absolute;
            left: .85rem;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
        }

    .table-ct {
        margin-bottom: 0;
    }

        .table-ct thead th {
            background: #f8fafc;
            color: #64748b;
            font-size: .75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #eef0f3;
            padding: .85rem 1rem;
            white-space: nowrap;
        }

        .table-ct tbody td {
            padding: .9rem 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
            color: #374151;
        }

        .table-ct tbody tr {
            transition: background .12s ease;
        }

            .table-ct tbody tr:hover {
                background: #f8faff;
            }

    .row-index {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: #f1f5f9;
        color: #64748b;
        font-size: .8rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .type-name {
        font-weight: 600;
        color: #111827;
    }

    .type-desc {
        color: #6b7280;
        font-size: .875rem;
    }

    .desc-empty {
        color: #cbd5e1;
        font-style: italic;
    }

    .btn-action {
        border: none;
        border-radius: 8px;
        padding: .4rem .8rem;
        font-size: .8rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        transition: transform .12s ease, box-shadow .12s ease;
    }

        .btn-action:hover {
            transform: translateY(-1px);
        }

    .btn-view {
        background: #ecfeff;
        color: #0891b2;
    }

        .btn-view:hover {
            background: #cffafe;
            color: #0e7490;
            box-shadow: 0 4px 10px rgba(8, 145, 178, .18);
        }

    .btn-edit {
        background: #eef2ff;
        color: #4f46e5;
    }

        .btn-edit:hover {
            background: #e0e7ff;
            color: #4338ca;
            box-shadow: 0 4px 10px rgba(79, 70, 229, .18);
        }

    .btn-delete {
        background: #fef2f2;
        color: #dc2626;
    }

        .btn-delete:hover {
            background: #fee2e2;
            color: #b91c1c;
            box-shadow: 0 4px 10px rgba(220, 38, 38, .18);
        }

    .empty-state {
        padding: 3.5rem 1rem;
        text-align: center;
        color: #9ca3af;
    }

        .empty-state .bi {
            font-size: 2.6rem;
            color: #d1d5db;
            display: block;
            margin-bottom: .75rem;
        }

        .empty-state p {
            margin-bottom: 1rem;
            font-size: .95rem;
        }
</style>

<div class="card ct-card mb-4">
    <div class="ct-header d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div class="d-flex align-items-center gap-3">
            <h5 class="ct-title">
                <span class="icon-wrap"><i class="bi bi-award"></i></span>
                <span>
                    Sertifika Türleri
                    <span class="ct-subtitle d-block">Sistemde tanımlı sertifika türlerini yönetin</span>
                </span>
            </h5>
            <span class="ct-count">@(Model?.Count ?? 0) kayıt</span>
        </div>
        <div class="d-flex align-items-center gap-2">
            <div class="search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" id="ctSearch" class="form-control ct-search" placeholder="Tür ara..." />
            </div>
            <a class="btn btn-add" href="/Admin/CertificateType/CreateCertificateType">
                <i class="bi bi-plus-lg me-1"></i> Yeni Tür Ekle
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-ct" id="ctTable">
                <thead>
                    <tr>
                        <th style="width: 6%;">#</th>
                        <th style="width: 24%;">Tür Adı</th>
                        <th style="width: 42%;">Açıklama</th>
                        <th style="width: 28%;" class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td><span class="row-index">@count</span></td>
                                <td><span class="type-name">@item.Ad</span></td>
                                <td>
                                    @if (string.IsNullOrEmpty(item.Aciklama))
                                    {
                                        <span class="type-desc desc-empty">Açıklama eklenmemiş</span>
                                    }
                                    else
                                    {
                                        <span class="type-desc">@item.Aciklama</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/Admin/CertificateType/TypeCertificates/@item.Id" class="btn btn-action btn-view">
                                        <i class="bi bi-collection"></i> Sertifikalar
                                    </a>
                                    <a href="/Admin/CertificateType/UpdateCertificateType/@item.Id" class="btn btn-action btn-edit">
                                        <i class="bi bi-pencil-square"></i> Düzenle
                                    </a>
                                    <button onclick="deleteCertificateType(@item.Id, '@item.Ad')" class="btn btn-action btn-delete">
                                        <i class="bi bi-trash3"></i> Sil
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4">
                                <div class="empty-state">
                                    <i class="bi bi-inbox"></i>
                                    <p>Henüz kayıtlı sertifika türü bulunmuyor.</p>
                                    <a class="btn btn-add" href="/Admin/CertificateType/CreateCertificateType">
                                        <i class="bi bi-plus-lg me-1"></i> İlk Türü Ekle
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function deleteCertificateType(id, name) {
        Swal.fire({
            title: "Emin misiniz?",
            html: `<b>${name}</b> türünü silmek üzeresiniz.<br>Bu işlem geri alınamaz!`,
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#dc2626",
            cancelButtonColor: "#6c757d",
            confirmButtonText: '<i class="bi bi-trash3 me-1"></i> Evet, sil',
            cancelButtonText: "İptal",
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/CertificateType/DeleteCertificateType/" + id;
            }
        });
    }

    // Basit istemci tarafı arama
    document.getElementById("ctSearch")?.addEventListener("input", function () {
        const term = this.value.toLowerCase().trim();
        document.querySelectorAll("#ctTable tbody tr").forEach(row => {
            if (row.querySelector(".empty-state")) return;
            row.style.display = row.textContent.toLowerCase().includes(term) ? "" : "none";
        });
    });
</script>
