@model HumanResources.WebUI.DTOs.DepartmentDtos.CreateDepartmentDto
@{
    ViewData["Title"] = "Yeni Departman Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var userList = ViewBag.Users as List<HumanResources.WebUI.DTOs.UserDtos.UserDto>;
}

<style>
    .dept-form-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(16, 24, 40, .06);
        overflow: hidden;
        max-width: 760px;
        margin: 0 auto;
    }

    .dept-form-header {
        background: #fff;
        border-bottom: 1px solid #eef0f3;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: .8rem;
    }

        .dept-form-header .icon-wrap {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, #14b8a6, #0d9488);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            flex-shrink: 0;
        }

    .dept-form-title {
        font-weight: 700;
        color: #1f2937;
        margin: 0;
    }

    .dept-form-subtitle {
        font-size: .82rem;
        color: #6b7280;
        margin: 2px 0 0;
    }

    .dept-form-body {
        padding: 1.75rem;
    }

    .dept-label {
        font-weight: 600;
        color: #374151;
        font-size: .88rem;
        margin-bottom: .4rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .dept-label .bi {
            color: #0d9488;
            font-size: .95rem;
        }

    .dept-input {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: .65rem .9rem;
        background: #f9fafb;
        transition: border-color .15s ease, box-shadow .15s ease, background .15s ease;
    }

        .dept-input:focus {
            background: #fff;
            border-color: #5eead4;
            box-shadow: 0 0 0 3px rgba(13, 148, 136, .15);
        }

    /* ===== Şık yönetici seçici ===== */
    .manager-picker {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
    }

    .manager-picker-selected {
        padding: 12px 14px;
        background: #f8f9fc;
        border-bottom: 1px solid #eef0f3;
    }

    .mp-empty {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #9ca3af;
        font-size: .88rem;
    }

        .mp-empty .bi {
            color: #cbd5e1;
        }

    .mp-selected-card {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .manager-list {
        max-height: 260px;
        overflow-y: auto;
    }

    .manager-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        cursor: pointer;
        border-bottom: 1px solid #f1f5f9;
        transition: background .12s ease;
    }

        .manager-item:last-child {
            border-bottom: none;
        }

        .manager-item:hover {
            background: #f0fdfa;
        }

        .manager-item.selected {
            background: #ccfbf1;
        }

    .mp-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .mp-avatar-initials {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #14b8a6, #0d9488);
        color: #fff;
        font-weight: 700;
        font-size: .82rem;
    }

    .mp-info {
        display: flex;
        flex-direction: column;
        line-height: 1.3;
        flex: 1;
    }

    .mp-name {
        font-weight: 600;
        color: #1f2937;
        font-size: .92rem;
    }

    .mp-role {
        font-size: .74rem;
        color: #0f766e;
        background: #ccfbf1;
        padding: 1px 8px;
        border-radius: 20px;
        align-self: flex-start;
        margin-top: 2px;
        display: inline-flex;
        align-items: center;
        gap: 3px;
    }

    .mp-check {
        color: #16a34a;
        opacity: 0;
        transition: opacity .12s ease;
        flex-shrink: 0;
    }

    .manager-item.selected .mp-check {
        opacity: 1;
    }

    .mp-no-managers {
        padding: 16px;
        color: #9ca3af;
        font-size: .88rem;
        text-align: center;
    }

    .dept-hint {
        font-size: .78rem;
        color: #9ca3af;
        margin-top: .35rem;
    }

    .dept-actions {
        border-top: 1px solid #f1f5f9;
        margin-top: 1.75rem;
        padding-top: 1.25rem;
    }

    .btn-cancel {
        border-radius: 10px;
        padding: .6rem 1.3rem;
        font-weight: 600;
        background: #f3f4f6;
        color: #4b5563;
        border: none;
    }

        .btn-cancel:hover {
            background: #e5e7eb;
            color: #374151;
        }

    .btn-create {
        border-radius: 10px;
        padding: .6rem 1.4rem;
        font-weight: 600;
        border: none;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: #fff;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        transition: transform .15s ease, box-shadow .15s ease;
    }

        .btn-create:hover {
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(34, 197, 94, .35);
        }
</style>

<div class="card dept-form-card mb-4">
    <div class="dept-form-header">
        <span class="icon-wrap"><i class="bi bi-building-add"></i></span>
        <div>
            <h5 class="dept-form-title">Yeni Departman Oluştur</h5>
            <p class="dept-form-subtitle">Departman bilgilerini girin ve yönetici atayın</p>
        </div>
    </div>
    <div class="card-body dept-form-body">
        <form asp-action="CreateDepartment" method="post" id="departmentForm" novalidate>

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label class="dept-label"><i class="bi bi-tag"></i> Departman Adı</label>
                <input type="text" asp-for="Ad" class="form-control dept-input" placeholder="Örn: Yazılım Geliştirme" maxlength="100" required />
                <span class="text-danger small" asp-validation-for="Ad"></span>
                <p class="dept-hint">Listelerde ve raporlarda görünecek kısa ve açık bir isim seçin.</p>
            </div>

            <div class="mb-2">
                <label class="dept-label"><i class="bi bi-person-badge"></i> Departman Yöneticisi <span class="text-muted fw-normal">(opsiyonel)</span></label>

                <input type="hidden" asp-for="YoneticiId" id="selectedYoneticiId" />

                <div class="manager-picker">
                    <div class="manager-picker-selected" id="managerPickerSelected">
                        <div class="mp-empty">
                            <i class="bi bi-person-dash"></i>
                            <span>Yönetici seçilmedi — atamak için aşağıdan birini seçin</span>
                        </div>
                    </div>

                    @if (userList != null && userList.Any())
                    {
                        <div class="manager-list">
                            @foreach (var u in userList)
                            {
                                var initials = $"{(string.IsNullOrEmpty(u.Ad) ? "" : u.Ad.Substring(0, 1))}{(string.IsNullOrEmpty(u.Soyad) ? "" : u.Soyad.Substring(0, 1))}".ToUpper();
                                <div class="manager-item" data-id="@u.Id" data-name="@u.Ad @u.Soyad" data-initials="@initials" data-photo="@u.FotografUrl">
                                    @if (!string.IsNullOrEmpty(u.FotografUrl))
                                    {
                                        <img src="@u.FotografUrl" class="mp-avatar" alt="@u.Ad" />
                                    }
                                    else
                                    {
                                        <span class="mp-avatar mp-avatar-initials">@initials</span>
                                    }
                                    <div class="mp-info">
                                        <span class="mp-name">@u.Ad @u.Soyad</span>
                                        <span class="mp-role"><i class="bi bi-shield-check"></i> Yönetici</span>
                                    </div>
                                    <span class="mp-check"><i class="bi bi-check-lg"></i></span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="mp-no-managers">
                            <i class="bi bi-info-circle me-1"></i> Sistemde "Yönetici" rolünde kullanıcı bulunmuyor.
                        </div>
                    }
                </div>
                <span class="text-danger small" asp-validation-for="YoneticiId"></span>
            </div>

            <div class="dept-actions d-flex justify-content-end">
                <a href="/Admin/Department/Index" class="btn btn-cancel me-2">
                    <i class="bi bi-x-lg me-1"></i> İptal
                </a>
                <button type="submit" class="btn btn-create">
                    <i class="bi bi-check-lg"></i> Oluştur
                </button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    (function () {
        const hidden = document.getElementById("selectedYoneticiId");
        const selectedBox = document.getElementById("managerPickerSelected");
        const items = document.querySelectorAll(".manager-item");

        function emptyHtml() {
            return `<div class="mp-empty"><i class="bi bi-person-dash"></i><span>Yönetici seçilmedi — atamak için aşağıdan birini seçin</span></div>`;
        }

        function renderSelected(item) {
            if (!item) { selectedBox.innerHTML = emptyHtml(); return; }
            const name = item.dataset.name;
            const initials = item.dataset.initials;
            const photo = item.dataset.photo;
            const avatarHtml = photo
                ? `<img src="${photo}" class="mp-avatar" />`
                : `<span class="mp-avatar mp-avatar-initials">${initials}</span>`;
            selectedBox.innerHTML = `
                <div class="mp-selected-card">
                    ${avatarHtml}
                    <div class="mp-info">
                        <span class="mp-name">${name}</span>
                        <span class="mp-role"><i class="bi bi-shield-check"></i> Seçili Yönetici</span>
                    </div>
                </div>`;
        }

        items.forEach(item => {
            item.addEventListener("click", function () {
                const already = this.classList.contains("selected");
                items.forEach(i => i.classList.remove("selected"));
                if (already) {
                    hidden.value = "";
                    renderSelected(null);
                } else {
                    this.classList.add("selected");
                    hidden.value = this.dataset.id;
                    renderSelected(this);
                }
            });
        });

        // Sayfa açılışında hidden'da değer varsa (validasyon dönüşü) seçili getir
        if (hidden.value) {
            const match = document.querySelector(`.manager-item[data-id="${hidden.value}"]`);
            if (match) { match.classList.add("selected"); renderSelected(match); }
        }
    })();

    document.getElementById('departmentForm').addEventListener('submit', function (e) {
        var form = this;
        if (!form.checkValidity()) { form.reportValidity(); e.preventDefault(); return; }
        e.preventDefault();
        Swal.fire({
            title: "Emin misiniz?",
            text: "Departman oluşturulacak.",
            icon: "question",
            showCancelButton: true,
            confirmButtonColor: "#16a34a",
            cancelButtonColor: "#6c757d",
            confirmButtonText: "Evet, kaydet",
            cancelButtonText: "İptal",
            reverseButtons: true
        }).then(res => { if (res.isConfirmed) form.submit(); });
    });
</script>
