@model HumanResources.Business.DTOs.DepartmentDtos.UpdateDepartmentDto
@{
    ViewData["Title"] = "Departman Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Doğru yol
}

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Departman Güncelleme Formu</h6>
    </div>
    <div class="card-body">
        <form asp-action="UpdateDepartment" method="post" id="updateForm">
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label>Departman Adı</label>
                <input type="text" asp-for="Ad" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label>Yönetici ID</label>
                <input type="number" asp-for="YoneticiId" class="form-control" />
            </div>

            <button type="button" class="btn btn-primary" onclick="submitUpdateForm()">Güncelle</button>
            <a asp-action="Index" class="btn btn-secondary">İptal</a>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function submitUpdateForm() {
        const form = document.getElementById('updateForm');
        if (form.checkValidity()) {
            Swal.fire({
                title: 'Güncellendi!',
                text: 'Departman bilgileri başarıyla kaydedildi.',
                icon: 'success',
                timer: 1500,
                showConfirmButton: false
            }).then(() => {
                form.submit();
            });
        } else {
            form.reportValidity();
        }
    }
</script>