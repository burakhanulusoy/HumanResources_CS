@model List<HumanResources.Business.DTOs.DepartmentDtos.ResultDepartmentDto>
@{
    ViewData["Title"] = "Departmanlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Doğru yol
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Departman Listesi</h6>
        <a asp-action="CreateDepartment" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle"></i> Yeni Departman Ekle
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Departman Adı</th>
                        <th>Yöneticisi</th>
                        <th class="text-center">Birim Sayısı</th>
                        <th class="text-center">Personel Sayısı</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="font-weight-bold">@item.Ad</td>
                            <td>@(string.IsNullOrEmpty(item.YoneticiAdSoyad) ? "Atanmadı" : item.YoneticiAdSoyad)</td>
                            <td class="text-center"><span class="badge bg-info text-dark">@item.BirimlerCount Birim</span></td>
                            <td class="text-center"><span class="badge bg-secondary">@item.PersonellerCount Personel</span></td>
                            <td class="text-center">
                                <a asp-action="DepartmentDetails" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">İncele / PDF</a>
                                <a asp-action="UpdateDepartment" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                                <button type="button" class="btn btn-danger btn-sm" onclick="confirmDelete(@item.Id, '@item.Ad')">Sil</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- SweetAlert2 kütüphanesinin projende olduğunu varsayarak CDN ekliyorum, varsa silebilirsin -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function confirmDelete(id, name) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: `"${name}" adlı departmanı silmek üzeresiniz. Bu işlem geri alınamaz!`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Evet, Sil!',
            cancelButtonText: 'İptal'
        }).then((result) => {
            if (result.isConfirmed) {
                // Onaylanırsa ilgili route'a yönlendir
                window.location.href = `/Admin/Department/DeleteDepartment/${id}`;
            }
        })
    }

    // Eğer Controller'dan TempData["Success"] gibi bir mesaj dönüyorsan burada yakalayabilirsin:
    // @@if(TempData["Success"] != null) { 
    //    Swal.fire('Başarılı!', '@TempData["Success"]', 'success'); 
    // }
</script>