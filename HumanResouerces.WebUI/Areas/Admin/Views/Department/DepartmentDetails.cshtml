@model HumanResources.WebUI.DTOs.DepartmentDtos.ResultDepartmentWithUserDto
@{
    ViewData["Title"] = $"{Model.Ad} - Departman Personel Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // Logonuzun yolu — dosyayı bu isimle wwwroot/assets/images klasörüne kaydedin
    string logoUrl = "/ImagesProject/Logo.png";

    // Sunum için basit, null-güvenli sayaç. Burada filtreleme YOK.
    // Silinmiş kayıtlar zaten AppDbContext'teki global query filter (SilindiMi == false) ile elenerek geliyor.
    int staffCount = Model.Personeller?.Count ?? 0;

    string yoneticiAdSoyad = Model.Yonetici != null ? $"{Model.Yonetici.Ad} {Model.Yonetici.Soyad}" : "Yönetici Atanmadı";

    string pdfFileName = $"Departman_Raporu_{Model.Ad.Replace(" ", "_")}_{DateTime.Now.ToString("dd_MM_yyyy")}.pdf";
}

<style>
    .toolbar {
        background: #fff;
        border: 1px solid #eef0f3;
        border-radius: 14px;
        padding: 14px 20px;
    }

    .btn-outline-back {
        background: #f3f4f6;
        color: #4b5563;
        border: 1px solid #e5e7eb;
        font-weight: 500;
        border-radius: 10px;
    }

        .btn-outline-back:hover {
            background: #e5e7eb;
            color: #1f2937;
        }

    .btn-download-pdf {
        background: #0B2545;
        border: none;
        color: #fff;
        font-weight: 600;
        border-radius: 10px;
        box-shadow: 0 4px 12px rgba(11,37,69,.25);
    }

        .btn-download-pdf:hover {
            background: #0d2c55;
            color: #fff;
        }

        .btn-download-pdf i {
            color: #29A8CC;
        }

    /* PDF İçeriği */
    #pdfContent {
        background: #ffffff;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #1a1a1a;
        border-radius: 4px;
        padding: 40px;
    }

    /* --- Logolu resmi başlık --- */
    .doc-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        border-bottom: 3px double #0B2545;
        padding-bottom: 14px;
        margin-bottom: 18px;
    }

        .doc-header .brand {
            display: flex;
            align-items: center;
            gap: 14px;
        }

            .doc-header .brand img {
                height: 58px;
                width: auto;
                display: block;
            }

        .doc-header .org-info h3 {
            margin: 0;
            font-size: 1.15rem;
            font-weight: 800;
            letter-spacing: .04em;
            color: #0B2545;
            text-transform: uppercase;
        }

            .doc-header .org-info h3 span {
                color: #29A8CC;
            }

        .doc-header .org-info .dept-line {
            margin: 3px 0 0;
            font-size: .8rem;
            font-weight: 700;
            color: #0B2545;
        }

        .doc-header .org-info p {
            margin: 1px 0 0;
            font-size: .74rem;
            color: #555;
        }

        .doc-header .doc-meta {
            text-align: right;
            font-size: .78rem;
            color: #333;
            line-height: 1.6;
        }

            .doc-header .doc-meta strong {
                color: #0B2545;
            }

    .doc-title {
        text-align: center;
        margin-bottom: 20px;
    }

        .doc-title h2 {
            font-size: 1.15rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .03em;
            margin: 0;
            color: #0B2545;
        }

        .doc-title .title-underline {
            width: 90px;
            height: 3px;
            background: #29A8CC;
            margin: 8px auto 0;
            border-radius: 2px;
        }

        .doc-title p {
            margin: 6px 0 0;
            font-size: .78rem;
            color: #444;
        }

    .doc-info-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 26px;
        font-size: .85rem;
    }

        .doc-info-table td {
            border: 1px solid #333;
            padding: 8px 12px;
        }

            .doc-info-table td.label {
                background: #eef2f7;
                font-weight: 700;
                color: #0B2545;
                width: 22%;
            }

    .doc-staff-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
        margin-bottom: 26px;
    }

        .doc-staff-table th {
            border: 1px solid #0B2545;
            background: #0B2545;
            color: #fff;
            padding: 9px 10px;
            font-weight: 700;
            text-transform: uppercase;
            font-size: .72rem;
            letter-spacing: .03em;
            text-align: left;
        }

        .doc-staff-table td {
            border: 1px solid #cbd5e1;
            padding: 8px 10px;
        }

        .doc-staff-table tbody tr:nth-child(even) {
            background: #f6f9fc;
        }

        .doc-staff-table td.idx {
            text-align: center;
            font-weight: 700;
            color: #0B2545;
        }

        .doc-staff-table .staff-name {
            font-weight: 700;
            color: #0B2545;
        }

        .doc-staff-table .empty-row td {
            text-align: center;
            font-style: italic;
            color: #555;
            padding: 18px;
        }

    .doc-signature-area {
        display: flex;
        justify-content: space-between;
        margin-top: 50px;
    }

    .doc-signature-box {
        width: 30%;
        text-align: center;
        font-size: .8rem;
    }

    .doc-signature-line {
        border-top: 1px solid #0B2545;
        margin-top: 50px;
        padding-top: 6px;
        font-weight: 700;
        color: #0B2545;
    }

    .doc-signature-name {
        margin-top: 3px;
        font-weight: 700;
        font-size: .82rem;
        color: #000;
    }

    .doc-footer {
        margin-top: 25px;
        border-top: 1px solid #0B2545;
        padding-top: 10px;
        font-size: .7rem;
        color: #444;
        display: flex;
        justify-content: space-between;
    }

        .doc-footer .conf {
            color: #0B2545;
            font-weight: 700;
        }
</style>

<div class="toolbar d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-back px-3">
        <i class="bi bi-arrow-left me-1"></i> Geri Dön
    </a>
    <button id="downloadPdfBtn" class="btn btn-download-pdf px-4">
        <i class="bi bi-file-earmark-pdf me-1"></i> Personel Listesini PDF İndir
    </button>
</div>

<div id="pdfContent" class="card shadow-sm">
    <div class="doc-header">
        <div class="brand">
            <img src="@logoUrl" alt="CS Savunma Logo" />
            <div class="org-info">
                <h3>ÖNCÜ SAVUNMA</h3>
                <div class="dept-line">İnsan Kaynakları Departmanı</div>
                <p>Departman ve Personel Yönetim Sistemi</p>
            </div>
        </div>
        <div class="doc-meta">
            <div><strong>Rapor No:</strong> DPT-@Model.Id.ToString("D4")-@DateTime.Now.ToString("yyyyMMdd")</div>
            <div><strong>Düzenleme Tarihi:</strong> @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</div>
            <div><strong>Durum:</strong> Onaylı</div>
        </div>
    </div>

    <div class="doc-title">
        <h2>Departman Personel Listesi Raporu</h2>
        <div class="title-underline"></div>
        <p>Kurum İçi Kadro ve Personel Dağılım Belgesi</p>
    </div>

    <table class="doc-info-table">
        <tr>
            <td class="label">Departman Adı</td>
            <td>@Model.Ad</td>
            <td class="label">Departman Yöneticisi</td>
            <td>@yoneticiAdSoyad</td>
        </tr>
        <tr>
            <td class="label">Toplam Personel</td>
            <td>@staffCount Kişi</td>
            <td class="label">Rapor Tarihi</td>
            <td>@DateTime.Now.ToString("dd.MM.yyyy")</td>
        </tr>
    </table>

    <table class="doc-staff-table">
        <thead>
            <tr>
                <th style="width: 6%;">#</th>
                <th style="width: 28%;">Adı Soyadı</th>
                <th style="width: 22%;">Birimi</th>
                <th style="width: 20%;">Telefon</th>
                <th style="width: 24%;">E-Posta</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Personeller != null && Model.Personeller.Any())
            {
                int pCount = 0;
                foreach (var p in Model.Personeller)
                {
                    pCount++;
                    <tr>
                        <td class="idx">@pCount</td>
                        <td class="staff-name">@p.Ad @p.Soyad</td>
                        <td>@(string.IsNullOrEmpty(p.BirimAd) ? "-" : p.BirimAd)</td>
                        <td>@(string.IsNullOrEmpty(p.PhoneNumber) ? "-" : p.PhoneNumber)</td>
                        <td>@(string.IsNullOrEmpty(p.Email) ? "-" : p.Email)</td>
                    </tr>
                }
            }
            else
            {
                <tr class="empty-row">
                    <td colspan="5">Bu departmana bağlı personel bulunmamaktadır.</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="doc-signature-area">
        <div class="doc-signature-box">
            <div class="doc-signature-line">İnsan Kaynakları Yetkilisi</div>
        </div>
        <div class="doc-signature-box">
            <div class="doc-signature-line">
                Departman Yöneticisi
                @if (Model.Yonetici != null)
                {
                    <div class="doc-signature-name">@yoneticiAdSoyad</div>
                }
            </div>
        </div>
        <div class="doc-signature-box">
            <div class="doc-signature-line">Genel Müdür Onayı</div>
        </div>
    </div>

    <div class="doc-footer">
        <span>Bu rapor sistemdeki güncel verilere göre otomatik oluşturulmuştur.</span>
        <span class="conf">GİZLİLİK SINIFI: KURUM İÇİ &nbsp;|&nbsp; Sayfa 1/1</span>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    document.getElementById('downloadPdfBtn').addEventListener('click', function () {
        var element = document.getElementById('pdfContent');
        var opt = {
            margin:      0.4,
            filename:    '@pdfFileName',
            image:       { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 3, useCORS: true, backgroundColor: '#ffffff' },
            jsPDF:       { unit: 'in', format: 'a4', orientation: 'portrait' },
            pagebreak:   { mode: ['css', 'legacy'] }
        };
        html2pdf().set(opt).from(element).save();
    });
</script>
