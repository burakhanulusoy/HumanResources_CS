@model List<HumanResources.WebUI.DTOs.UserDtos.ResultUserDto>
@{
    ViewData["Title"] = "Personel Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0"><i class="bi bi-people text-primary me-2"></i>Personel Listesi</h3>
    <a asp-action="CreateUser" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Yeni Personel Ekle
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Ad Soyad</th>
                    <th>Departman</th>
                    <th>Birim</th>
                    <th>Telefon</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="fw-semibold text-nowrap">@user.Ad @user.Soyad</td>
                        <td class="text-muted">@(user.Departman?.Ad ?? "-")</td>
                        <td class="text-muted">@(user.Birim?.Ad ?? "-")</td>
                        <td>@(string.IsNullOrEmpty(user.PhoneNumber) ? "-" : user.PhoneNumber)</td>
                        <td class="text-end text-nowrap">
                            <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-info" title="İncele">
                                <i class="bi bi-eye me-1"></i>İncele
                            </a>
                            <a asp-action="EducationDetails" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary" title="Eğitim Bilgileri">
                                <i class="bi bi-mortarboard me-1"></i>Eğitimleri
                            </a>
                            <a asp-controller="Certificate" asp-action="UserCertificates" asp-route-userId="@user.Id" class="btn btn-sm btn-outline-success" title="Sertifika Belgeleri">
                                <i class="bi bi-patch-check me-1"></i>Sertifikaları
                            </a>
                            <a asp-action="UserItems" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning" title="Zimmet Bilgileri">
                                <i class="bi bi-box-seam me-1"></i>Zimmetleri
                            </a>
                            <a asp-action="UpdateUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-secondary" title="Düzenle">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline js-delete-form">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.querySelectorAll('.js-delete-form').forEach(function (form) {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            Swal.fire({
                title: 'Emin misiniz?',
                text: 'Bu personel sistemden pasif hale getirilecek.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, çıkar',
                cancelButtonText: 'Vazgeç',
                confirmButtonColor: '#d33'
            }).then(function (result) {
                if (result.isConfirmed) form.submit();
            });
        });
    });

    (function () {
        const params = new URLSearchParams(window.location.search);
        const basarili = params.get('basarili');
        const mesajlar = {
            olusturuldu: 'Personel başarıyla eklendi.',
            guncellendi: 'Personel bilgileri güncellendi.',
            silindi: 'Personel kaydı kapatıldı.'
        };
        if (basarili && mesajlar[basarili]) {
            Swal.fire({
                icon: 'success', title: mesajlar[basarili], toast: true,
                position: 'top-end', showConfirmButton: false, timer: 2200, timerProgressBar: true
            });
            params.delete('basarili');
            const yeniUrl = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
            window.history.replaceState({}, '', yeniUrl);
        }
    })();
</script>