@model HumanResouerces.WebUI.Areas.Admin.Models.UserItemsViewModel
@{
    ViewData["Title"] = "Personel Zimmetleri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string logoUrl = "/ImagesProject/Logo.png";
    string pdfFileName = $"Zimmet_Listesi_{Model.Kullanici?.Ad}_{Model.Kullanici?.Soyad}.pdf";
}

<style>
    .btn-download-pdf {
        background: #0B2545;
        border: none;
        color: #fff;
        font-weight: 600;
        border-radius: 10px;
        box-shadow: 0 4px 12px rgba(11,37,69,.25);
    }

        .btn-download-pdf:hover {
            background: #0d2c55;
            color: #fff;
        }

        .btn-download-pdf i {
            color: #29A8CC;
        }

    /* ---- Toplu PDF belge şablonu ---- */
    #pdfContent {
        background: #ffffff;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #1a1a1a;
        border-radius: 4px;
        padding: 40px;
    }

    .doc-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 3px double #0B2545;
        padding-bottom: 18px;
        margin-bottom: 20px;
    }

        .doc-header .brand {
            display: flex;
            align-items: center;
            gap: 18px;
        }

            .doc-header .brand img {
                height: 90px;
                width: auto;
                display: block;
            }

        .doc-header .org-info h3 {
            margin: 0;
            font-size: 1.35rem;
            font-weight: 800;
            letter-spacing: .04em;
            color: #0B2545;
            text-transform: uppercase;
        }

        .doc-header .org-info p {
            margin: 3px 0 0;
            font-size: .85rem;
            color: #555;
        }

        .doc-header .doc-meta {
            text-align: right;
            font-size: .78rem;
            color: #333;
            line-height: 1.6;
        }

            .doc-header .doc-meta strong {
                color: #0B2545;
            }

    .doc-title {
        text-align: center;
        margin-bottom: 20px;
    }

        .doc-title h2 {
            font-size: 1.15rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .03em;
            margin: 0;
            color: #0B2545;
        }

        .doc-title .title-underline {
            width: 90px;
            height: 3px;
            background: #29A8CC;
            margin: 8px auto 0;
            border-radius: 2px;
        }

    .doc-info-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 26px;
        font-size: .88rem;
    }

        .doc-info-table td {
            border: 1px solid #333;
            padding: 9px 12px;
        }

            .doc-info-table td.label {
                background: #eef2f7;
                font-weight: 700;
                color: #0B2545;
                width: 22%;
            }

    .doc-items-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
        margin-bottom: 30px;
    }

        .doc-items-table th {
            border: 1px solid #0B2545;
            background: #0B2545;
            color: #fff;
            padding: 9px 10px;
            font-weight: 700;
            text-transform: uppercase;
            font-size: .72rem;
            letter-spacing: .03em;
            text-align: left;
        }

        .doc-items-table td {
            border: 1px solid #cbd5e1;
            padding: 8px 10px;
        }

        .doc-items-table tbody tr:nth-child(even) {
            background: #f6f9fc;
        }

        .doc-items-table .empty-row td {
            text-align: center;
            font-style: italic;
            color: #555;
            padding: 18px;
        }

    .doc-declaration {
        font-size: .85rem;
        color: #333;
        line-height: 1.7;
        margin-bottom: 40px;
        text-align: justify;
    }

    .doc-signature-area {
        display: flex;
        justify-content: space-between;
        margin-top: 30px;
        gap: 20px;
    }

    .doc-signature-box {
        width: 30%;
        text-align: center;
        font-size: .82rem;
    }

    .doc-signature-line {
        border-top: 1px solid #0B2545;
        margin-top: 60px;
        padding-top: 6px;
        font-weight: 700;
        color: #0B2545;
    }

    .doc-signature-role {
        font-size: .74rem;
        color: #64748b;
        margin-top: 2px;
    }

    .doc-footer {
        margin-top: 30px;
        border-top: 1px solid #0B2545;
        padding-top: 10px;
        font-size: .7rem;
        color: #444;
        display: flex;
        justify-content: space-between;
    }

        .doc-footer .conf {
            color: #0B2545;
            font-weight: 700;
        }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0"><i class="bi bi-box-seam me-2"></i>Zimmet Bilgileri</h3>
    <div class="d-flex gap-2">
        <button id="downloadAllPdfBtn" class="btn btn-download-pdf">
            <i class="bi bi-file-earmark-pdf me-1"></i>Tüm Zimmetleri PDF İndir
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Personel Listesine Dön
        </a>
    </div>
</div>

@* ----- Ekranda görünen özet kartlar (PDF'e dahil değil) ----- *@
<div class="row g-4 mb-4">
    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                @if (!string.IsNullOrEmpty(Model.Kullanici?.FotografUrl))
                {
                    <img src="@Model.Kullanici.FotografUrl" class="rounded-circle mb-3"
                         style="width:100px;height:100px;object-fit:cover;" alt="Profil" />
                }
                else
                {
                    <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center mb-3"
                         style="width:100px;height:100px;font-size:1.8rem;">
                        @Model.Kullanici?.Ad?[0]@Model.Kullanici?.Soyad?[0]
                    </div>
                }
                <h5 class="mb-1">@Model.Kullanici?.Ad @Model.Kullanici?.Soyad</h5>
                <p class="text-muted small mb-3">Sicil: @Model.Kullanici?.SicilNo</p>

                <ul class="list-group list-group-flush text-start">
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Departman</span>
                        <span>@(Model.Kullanici?.Departman?.Ad ?? "-")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Birim</span>
                        <span>@(Model.Kullanici?.Birim?.Ad ?? "-")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Toplam Zimmet</span>
                        <span class="badge bg-primary rounded-pill">@Model.Zimmetler.Count</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-box-seam me-2"></i>Zimmet Listesi</span>
                <span class="badge bg-secondary rounded-pill">@Model.Zimmetler.Count kayıt</span>
            </div>
            <div class="card-body p-0">
                @if (Model.Zimmetler.Count > 0)
                {
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Zimmet Türü</th>
                                <th>Marka / Model</th>
                                <th>Teslim Tarihi</th>
                                <th>İade / Süre</th>
                                <th class="text-center">Durum</th>
                                <th class="text-end">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var z in Model.Zimmetler)
                            {
                                <tr>
                                    <td class="fw-semibold">@z.Demirbas?.ZimmetTuru?.Ad</td>
                                    <td class="text-muted">
                                        @(z.Demirbas == null ? "-" : $"{z.Demirbas.Marka} {z.Demirbas.Model}")
                                    </td>
                                    <td>@z.TeslimTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        @if (z.SuresizMi)
                                        {
                                            <span class="badge bg-info-subtle text-info-emphasis"><i class="bi bi-infinity me-1"></i>Süresiz</span>
                                        }
                                        else if (z.IadeTarihi.HasValue)
                                        {
                                            @z.IadeTarihi.Value.ToString("dd.MM.yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @switch (z.Durumu.ToString())
                                        {
                                            case "Aktif":
                                                <span class="badge bg-success">Aktif</span>
                                                break;
                                            case "IadeEdildi":
                                                <span class="badge bg-secondary">İade Edildi</span>
                                                break;
                                            case "Arizali":
                                                <span class="badge bg-warning text-dark">Arızalı</span>
                                                break;
                                            case "Kayip":
                                                <span class="badge bg-danger">Kayıp</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-controller="Item" asp-action="ZimmetBelgesi" asp-route-id="@z.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-file-earmark-text me-1"></i>Tekil Belge
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        Bu personelin üzerinde herhangi bir zimmet bulunmuyor.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ----- PDF'e dönüştürülecek gizli/asıl belge alanı ----- *@
<div id="pdfContent" class="card shadow-sm">
    <div class="doc-header">
        <div class="brand">
            <img src="@logoUrl" alt="Logo" />
            <div class="org-info">
                <h3>ÖNCÜ SAVUNMA</h3>
                <p>İnsan Kaynakları – Toplu Zimmet Listesi Belgesi</p>
            </div>
        </div>
        <div class="doc-meta">
            <div><strong>Belge No:</strong> ZMT-LIST-@Model.Kullanici?.Id.ToString("D4")-@DateTime.Now.ToString("yyyyMMdd")</div>
            <div><strong>Düzenleme Tarihi:</strong> @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</div>
            <div><strong>Durum:</strong> Onaylı</div>
        </div>
    </div>

    <div class="doc-title">
        <h2>Personel Zimmet Listesi</h2>
        <div class="title-underline"></div>
    </div>

    <table class="doc-info-table">
        <tr>
            <td class="label">Personel Adı Soyadı</td>
            <td>@Model.Kullanici?.Ad @Model.Kullanici?.Soyad</td>
            <td class="label">Sicil No</td>
            <td>@(Model.Kullanici?.SicilNo ?? "-")</td>
        </tr>
        <tr>
            <td class="label">Departman / Birim</td>
            <td>@(Model.Kullanici?.Departman?.Ad ?? "-") / @(Model.Kullanici?.Birim?.Ad ?? "-")</td>
            <td class="label">Amir</td>
            <td>@(Model.Kullanici?.AmirAdSoyad ?? "-")</td>
        </tr>
        <tr>
            <td class="label">Toplam Zimmet</td>
            <td colspan="3">@Model.Zimmetler.Count adet demirbaş/ekipman</td>
        </tr>
    </table>

    <table class="doc-items-table">
        <thead>
            <tr>
                <th style="width: 5%;">#</th>
                <th style="width: 20%;">Zimmet Türü</th>
                <th style="width: 20%;">Marka / Model</th>
                <th style="width: 15%;">Seri No</th>
                <th style="width: 15%;">Teslim Tarihi</th>
                <th style="width: 12%;">İade / Süre</th>
                <th style="width: 13%;">Durum</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Zimmetler.Count > 0)
            {
                int sira = 0;
                foreach (var z in Model.Zimmetler)
                {
                    sira++;
                    <tr>
                        <td>@sira</td>
                        <td>@(z.Demirbas?.ZimmetTuru?.Ad ?? "-")</td>
                        <td>@(z.Demirbas == null ? "-" : $"{z.Demirbas.Marka} {z.Demirbas.Model}")</td>
                        <td>@(string.IsNullOrEmpty(z.Demirbas?.SeriNumarasi) ? "-" : z.Demirbas.SeriNumarasi)</td>
                        <td>@z.TeslimTarihi.ToString("dd.MM.yyyy")</td>
                        <td>
                            @(z.SuresizMi
                                                ? "Süresiz"
                                                : (z.IadeTarihi.HasValue && z.IadeTarihi.Value.Year > 2000
                                                ? z.IadeTarihi.Value.ToString("dd.MM.yyyy")
                                                : "Devam Ediyor"))
                </td>
                <td>@z.Durumu</td>
            </tr>
                        }
            }
            else
            {
                <tr class="empty-row">
                    <td colspan="7">Bu personel üzerinde kayıtlı zimmet bulunmamaktadır.</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="doc-declaration">
        Yukarıda dökümü verilen tüm demirbaş/ekipman, işbu belge tarihi itibarıyla çalışma amacıyla kullanılmak
        üzere adı geçen personele eksiksiz ve çalışır durumda teslim edilmiştir. Personel, teslim aldığı ekipmanları
        işyeri kurallarına uygun şekilde kullanmayı, özenle korumayı ve iş ilişkisinin sona ermesi veya talep
        edilmesi halinde aynı durumda iade etmeyi kabul ve taahhüt eder.
    </div>

    <div class="doc-signature-area">
        <div class="doc-signature-box">
            <div class="doc-signature-line">İnsan Kaynakları Yetkilisi</div>
            <div class="doc-signature-role">Onay</div>
        </div>
        <div class="doc-signature-box">
            <div class="doc-signature-line">@(Model.Kullanici?.AmirAdSoyad ?? "Amir")</div>
            <div class="doc-signature-role">Bağlı Olduğu Amir</div>
        </div>
        <div class="doc-signature-box">
            <div class="doc-signature-line">@Model.Kullanici?.Ad @Model.Kullanici?.Soyad</div>
            <div class="doc-signature-role">Teslim Alan Personel</div>
        </div>
    </div>

    <div class="doc-footer">
        <span>Bu belge sistem tarafından otomatik oluşturulmuştur.</span>
        <span class="conf">GİZLİLİK SINIFI: KURUM İÇİ &nbsp;|&nbsp; Sayfa 1/1</span>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    document.getElementById('downloadAllPdfBtn').addEventListener('click', function () {
        var element = document.getElementById('pdfContent');
        var opt = {
            margin: 0.4,
            filename: '@pdfFileName',
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 3, useCORS: true, backgroundColor: '#ffffff' },
            jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' },
            pagebreak: { mode: ['css', 'legacy'] }
        };
        html2pdf().set(opt).from(element).save();
    });
</script>