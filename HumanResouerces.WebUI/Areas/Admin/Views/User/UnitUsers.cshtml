@model List<HumanResources.Business.DTOs.UserDtos.ResultUserDto>
@{
    // Birim adını doğrudan modelin içindeki ilk kayıttan çekiyoruz
    string birimAd = Model != null && Model.Any() ? Model.First().Birim?.Ad : "İlgili Birim";

    ViewData["Title"] = $"{birimAd} - Personeller";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int pCount = 0;
}

<style>
    :root {
        --navy: #0B2545;
        --navy-2: #143A6B;
        --cyan: #29A8CC;
        --cyan-soft: #EAF6FA;
        --ink: #1F2A37;
        --muted: #64748B;
        --line: #E4E9F0;
        --soft: #F7F9FC;
    }

    .toolbar {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 14px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn-outline-back {
        background: var(--soft);
        color: #475569;
        border: 1px solid var(--line);
        font-weight: 600;
        border-radius: 10px;
        padding: .5rem 1rem;
        transition: background .15s ease;
    }

        .btn-outline-back:hover {
            background: #eef2f7;
            color: #1f2937;
        }

    .unit-context {
        display: flex;
        align-items: center;
        gap: .8rem;
    }

        .unit-context .icon-wrap {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--navy), var(--navy-2));
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

            .unit-context .icon-wrap i {
                color: var(--cyan);
            }

        .unit-context h5 {
            margin: 0;
            font-weight: 700;
            color: var(--navy);
        }

        .unit-context .meta {
            font-size: .8rem;
            color: var(--muted);
            margin-top: 2px;
            display: flex;
            gap: .8rem;
            flex-wrap: wrap;
        }

            .unit-context .meta span {
                display: inline-flex;
                align-items: center;
                gap: .3rem;
            }

    /* ---- Arama motoru ---- */
    .search-bar {
        display: flex;
        align-items: center;
        gap: .75rem;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 18px;
        box-shadow: 0 2px 10px rgba(16,24,40,.04);
        transition: border-color .15s ease, box-shadow .15s ease;
    }

        .search-bar:focus-within {
            border-color: var(--cyan);
            box-shadow: 0 0 0 3px rgba(41,168,204,.12);
        }

        .search-bar .search-icon {
            color: var(--navy);
            font-size: 1.15rem;
            flex-shrink: 0;
        }

        .search-bar input {
            border: none;
            outline: none;
            flex: 1;
            font-size: .95rem;
            color: var(--ink);
            background: transparent;
        }

            .search-bar input::placeholder {
                color: #9aa5b4;
            }

    .search-count {
        font-size: .78rem;
        font-weight: 600;
        color: var(--navy);
        background: var(--cyan-soft);
        border-radius: 999px;
        padding: .28rem .7rem;
        white-space: nowrap;
    }

    .search-clear {
        border: none;
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        font-size: 1.1rem;
        line-height: 1;
        display: none;
    }

        .search-clear:hover {
            color: var(--navy);
        }

    .staff-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(16, 24, 40, .06);
        overflow: hidden;
    }

    .table-staff {
        margin-bottom: 0;
    }

        .table-staff thead th {
            background: var(--soft);
            color: var(--muted);
            font-size: .75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid var(--line);
            padding: .85rem 1rem;
        }

        .table-staff tbody td {
            padding: .9rem 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
            color: #374151;
        }

        .table-staff tbody tr.staff-row:hover {
            background: #f6fbfd;
        }

    /* Arama eşleşmesi vurgusu */
    mark.hl {
        background: #fff2b8;
        color: inherit;
        padding: 0 1px;
        border-radius: 2px;
    }

    .row-index {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: var(--soft);
        color: var(--muted);
        font-size: .8rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .staff-name {
        font-weight: 700;
        color: var(--navy);
        display: block;
        margin-bottom: 2px;
    }

    .staff-contact {
        font-size: 12.5px;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 4px;
        margin-top: 2px;
    }

    .role-badge {
        background: var(--cyan-soft);
        color: var(--navy);
        font-size: .75rem;
        font-weight: 600;
        border-radius: 999px;
        padding: .3rem .75rem;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        border: 1px solid rgba(41,168,204,.25);
    }

    .dept-badge {
        background: var(--soft);
        color: var(--navy);
        font-size: .75rem;
        font-weight: 600;
        border-radius: 999px;
        padding: .3rem .75rem;
        display: inline-flex;
        align-items: center;
        width: fit-content;
        border: 1px solid var(--line);
    }

    .unit-badge {
        background: #eef6fb;
        color: var(--navy-2);
        font-size: .75rem;
        font-weight: 600;
        border-radius: 999px;
        padding: .3rem .75rem;
        display: inline-flex;
        align-items: center;
        width: fit-content;
        margin-top: 4px;
        border: 1px solid rgba(20,58,107,.15);
    }

    .btn-profile {
        background: var(--navy);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .42rem .9rem;
        font-size: .8rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        transition: transform .12s ease, box-shadow .12s ease, background .12s ease;
    }

        .btn-profile i {
            color: var(--cyan);
        }

        .btn-profile:hover {
            background: #0d2c55;
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(11,37,69,.25);
        }

    .empty-state {
        padding: 3.5rem 1rem;
        text-align: center;
        color: #9ca3af;
    }

        .empty-state .bi {
            font-size: 2.6rem;
            color: #d1d5db;
            display: block;
            margin-bottom: .75rem;
        }
</style>

<div class="toolbar mb-3">
    <div class="unit-context">
        <span class="icon-wrap"><i class="bi bi-diagram-3"></i></span>
        <div>
            <h5>@birimAd - Personel Listesi</h5>
            <div class="meta">
                <span><i class="bi bi-people"></i> Toplam @(Model?.Count ?? 0) Personel Kayıtlı</span>
            </div>
        </div>
    </div>
    <button onclick="history.back()" class="btn btn-outline-back">
        <i class="bi bi-arrow-left me-1"></i> Birimlere Dön
    </button>
</div>

<!-- ARAMA MOTORU -->
<div class="search-bar">
    <i class="bi bi-search search-icon"></i>
    <input type="text" id="staffSearch" autocomplete="off"
           placeholder="Personel ara: ad soyad, e-posta, telefon, departman, birim veya amir..." />
    <button type="button" id="searchClear" class="search-clear" title="Temizle">&times;</button>
    <span class="search-count" id="searchCount">@(Model?.Count ?? 0) personel</span>
</div>

<div class="card staff-card mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-staff" id="staffTable">
                <thead>
                    <tr>
                        <th style="width: 5%;" class="text-center">#</th>
                        <th style="width: 30%;">Personel & İletişim</th>
                        <th style="width: 25%;">Departman & Birim</th>
                        <th style="width: 20%;">Bağlı Olduğu Amir</th>
                        <th style="width: 20%;" class="text-end pe-4">İşlem</th>
                    </tr>
                </thead>
                <tbody id="staffBody">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            pCount++;
                            string dep = string.IsNullOrEmpty(user.Departman?.Ad) ? "Belirtilmedi" : user.Departman.Ad;
                            string bir = string.IsNullOrEmpty(user.Birim?.Ad) ? "Belirtilmedi" : user.Birim.Ad;
                            string amir = string.IsNullOrEmpty(user.AmirAdSoyad) ? "" : user.AmirAdSoyad;
                            string aramaMetni = $"{user.Ad} {user.Soyad} {user.Email} {user.PhoneNumber} {dep} {bir} {amir}".ToLower();
                            <tr class="staff-row" data-search="@aramaMetni">
                                <td class="text-center"><span class="row-index">@pCount</span></td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@(string.IsNullOrEmpty(user.FotografUrl) ? "/assets/images/admin.png" : user.FotografUrl)"
                                             class="rounded-circle shadow-sm" style="width: 48px; height: 48px; object-fit: cover;" alt="Profil">
                                        <div>
                                            <span class="staff-name">@user.Ad @user.Soyad</span>
                                            <span class="staff-contact">
                                                <i class="bi bi-envelope"></i> @(string.IsNullOrEmpty(user.Email) ? "-" : user.Email)
                                            </span>
                                            <span class="staff-contact">
                                                <i class="bi bi-telephone"></i> @(string.IsNullOrEmpty(user.PhoneNumber) ? "-" : user.PhoneNumber)
                                            </span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="dept-badge">
                                            <i class="bi bi-building me-1"></i> @dep
                                        </span>
                                        <span class="unit-badge">
                                            <i class="bi bi-diagram-3 me-1"></i> @bir
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(user.AmirAdSoyad))
                                    {
                                        <span class="role-badge">
                                            <i class="bi bi-person-badge"></i> @user.AmirAdSoyad
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic fs-13"><i class="bi bi-person-dash me-1"></i>Amir Atanmadı</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/Admin/User/Details/@user.Id" class="btn-profile">
                                        <i class="bi bi-person-lines-fill"></i> Profili İncele
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="bi bi-people"></i>
                                    <p class="mb-0">Bu birime henüz herhangi bir personel atanmamıştır.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                <!-- Arama sonucu boşsa gösterilecek satır -->
                <tbody id="noResultBody" style="display:none;">
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <i class="bi bi-search"></i>
                                <p class="mb-0">Aramanızla eşleşen personel bulunamadı.</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    (function () {
        var input = document.getElementById('staffSearch');
        var clearBtn = document.getElementById('searchClear');
        var countEl = document.getElementById('searchCount');
        var noResult = document.getElementById('noResultBody');
        var rows = Array.prototype.slice.call(document.querySelectorAll('#staffBody tr.staff-row'));
        var total = rows.length;

        if (!input || total === 0) return;

        function normalize(str) {
            // Türkçe karakter duyarsız arama (İ/ı, Ş, Ğ, Ü, Ö, Ç)
            return (str || '')
                .toLocaleLowerCase('tr-TR')
                .replace(/ı/g, 'i').replace(/İ/g, 'i')
                .replace(/ş/g, 's').replace(/ğ/g, 'g')
                .replace(/ü/g, 'u').replace(/ö/g, 'o').replace(/ç/g, 'c');
        }

        function updateCount(visible) {
            if (input.value.trim() === '') {
                countEl.textContent = total + ' personel';
            } else {
                countEl.textContent = visible + ' / ' + total + ' personel';
            }
        }

        function filter() {
            var q = normalize(input.value.trim());
            var visible = 0;

            rows.forEach(function (row) {
                var hay = normalize(row.getAttribute('data-search'));
                var match = q === '' || hay.indexOf(q) !== -1;
                row.style.display = match ? '' : 'none';
                if (match) {
                    visible++;
                    // görünen satırları yeniden numarala
                    var idx = row.querySelector('.row-index');
                    if (idx) idx.textContent = visible;
                }
            });

            noResult.style.display = (visible === 0) ? '' : 'none';
            clearBtn.style.display = (input.value.length > 0) ? 'inline' : 'none';
            updateCount(visible);
        }

        input.addEventListener('input', filter);
        clearBtn.addEventListener('click', function () {
            input.value = '';
            input.focus();
            filter();
        });
        // Esc ile temizle
        input.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { input.value = ''; filter(); }
        });
    })();
</script>
