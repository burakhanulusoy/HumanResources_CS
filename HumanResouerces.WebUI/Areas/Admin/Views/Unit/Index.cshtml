@model List<HumanResources.WebUI.DTOs.UnitDtos.ResultUnitDto>
@{
    ViewData["Title"] = "Birimler";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
    int totalStaff = Model?.Sum(u => u.PersonellerCount) ?? 0;
}

<style>
    /* ===== Özet kartları ===== */
    .stat-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(16, 24, 40, .06);
        padding: 1.1rem 1.4rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        background: #fff;
        height: 100%;
    }

    .stat-icon {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }

        .stat-icon.blue {
            background: #eff6ff;
            color: #2563eb;
        }

        .stat-icon.purple {
            background: #f5f3ff;
            color: #7c3aed;
        }

    .stat-value {
        font-size: 1.35rem;
        font-weight: 700;
        color: #111827;
        line-height: 1.1;
        margin: 0;
    }

    .stat-label {
        font-size: .78rem;
        color: #6b7280;
        margin: 2px 0 0;
    }

    /* ===== Ana kart ===== */
    .unit-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(16, 24, 40, .06);
        overflow: hidden;
    }

    .unit-header {
        background: #fff;
        border-bottom: 1px solid #eef0f3;
        padding: 1.25rem 1.5rem;
    }

    .unit-title {
        font-weight: 700;
        color: #1f2937;
        margin: 0;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

        .unit-title .icon-wrap {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, #0ea5e9, #2563eb);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
        }

    .unit-subtitle {
        font-size: .82rem;
        color: #6b7280;
        margin: 2px 0 0;
    }

    .btn-add {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        border: none;
        color: #fff;
        border-radius: 10px;
        padding: .55rem 1.1rem;
        font-weight: 600;
        transition: transform .15s ease, box-shadow .15s ease;
    }

        .btn-add:hover {
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(34, 197, 94, .35);
        }

    .unit-search {
        max-width: 280px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        padding-left: 2.4rem;
        background: #f9fafb;
    }

        .unit-search:focus {
            background: #fff;
            border-color: #93c5fd;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, .15);
        }

    .search-wrap {
        position: relative;
    }

        .search-wrap .bi-search {
            position: absolute;
            left: .85rem;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
        }

    /* ===== Tablo ===== */
    .table-unit {
        margin-bottom: 0;
    }

        .table-unit thead th {
            background: #f8fafc;
            color: #64748b;
            font-size: .75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #eef0f3;
            padding: .85rem 1rem;
            white-space: nowrap;
        }

        .table-unit tbody td {
            padding: .9rem 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
            color: #374151;
        }

        .table-unit tbody tr {
            transition: background .12s ease;
        }

            .table-unit tbody tr:hover {
                background: #f8faff;
            }

    .row-index {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: #f1f5f9;
        color: #64748b;
        font-size: .8rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .unit-name {
        font-weight: 600;
        color: #111827;
    }

    .dept-badge {
        background: #f0f9ff;
        color: #0369a1;
        font-size: .78rem;
        font-weight: 600;
        border-radius: 999px;
        padding: .3rem .75rem;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

    .staff-badge {
        background: #f5f3ff;
        color: #7c3aed;
        font-size: .78rem;
        font-weight: 600;
        border-radius: 999px;
        padding: .3rem .75rem;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

        .staff-badge.empty {
            background: #f8fafc;
            color: #94a3b8;
        }

    /* ===== Aksiyon butonları ===== */
    .btn-action {
        border: none;
        border-radius: 8px;
        padding: .4rem .8rem;
        font-size: .8rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        transition: transform .12s ease, box-shadow .12s ease;
    }

        .btn-action:hover {
            transform: translateY(-1px);
        }

    .btn-view {
        background: #ecfeff;
        color: #0891b2;
    }

        .btn-view:hover {
            background: #cffafe;
            color: #0e7490;
            box-shadow: 0 4px 10px rgba(8, 145, 178, .18);
        }

    .btn-edit {
        background: #eef2ff;
        color: #4f46e5;
    }

        .btn-edit:hover {
            background: #e0e7ff;
            color: #4338ca;
            box-shadow: 0 4px 10px rgba(79, 70, 229, .18);
        }

    .btn-delete {
        background: #fef2f2;
        color: #dc2626;
    }

        .btn-delete:hover {
            background: #fee2e2;
            color: #b91c1c;
            box-shadow: 0 4px 10px rgba(220, 38, 38, .18);
        }

    /* ===== Boş durum ===== */
    .empty-state {
        padding: 3.5rem 1rem;
        text-align: center;
        color: #9ca3af;
    }

        .empty-state .bi {
            font-size: 2.6rem;
            color: #d1d5db;
            display: block;
            margin-bottom: .75rem;
        }

        .empty-state p {
            margin-bottom: 1rem;
            font-size: .95rem;
        }
</style>

<!-- Özet kartları -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="stat-card">
            <span class="stat-icon blue"><i class="bi bi-diagram-3"></i></span>
            <div>
                <p class="stat-value">@(Model?.Count ?? 0)</p>
                <p class="stat-label">Toplam Birim</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="stat-card">
            <span class="stat-icon purple"><i class="bi bi-people"></i></span>
            <div>
                <p class="stat-value">@totalStaff</p>
                <p class="stat-label">Birimlere Atanmış Toplam Personel</p>
            </div>
        </div>
    </div>
</div>

<!-- Birim listesi -->
<div class="card unit-card mb-4">
    <div class="unit-header d-flex flex-wrap justify-content-between align-items-center gap-3">
        <h5 class="unit-title">
            <span class="icon-wrap"><i class="bi bi-diagram-3"></i></span>
            <span>
                Birimler
                <span class="unit-subtitle d-block">Departmanlara bağlı birimleri yönetin</span>
            </span>
        </h5>
        <div class="d-flex align-items-center gap-2">
            <div class="search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" id="unitSearch" class="form-control unit-search" placeholder="Birim veya departman ara..." />
            </div>
            <a class="btn btn-add" href="/Admin/Unit/CreateUnit">
                <i class="bi bi-plus-lg me-1"></i> Yeni Birim Ekle
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-unit" id="unitTable">
                <thead>
                    <tr>
                        <th style="width: 5%;">#</th>
                        <th style="width: 25%;">Birim Adı</th>
                        <th style="width: 22%;">Bağlı Departman</th>
                        <th style="width: 15%;">Personel</th>
                        <th style="width: 33%;" class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td><span class="row-index">@count</span></td>
                                <td><span class="unit-name">@item.Ad</span></td>
                                <td>
                                    <span class="dept-badge">
                                        <i class="bi bi-building"></i> @item.DepartmanAd
                                    </span>
                                </td>
                                <td>
                                    @if (item.PersonellerCount > 0)
                                    {
                                        <span class="staff-badge">
                                            <i class="bi bi-people"></i> @item.PersonellerCount kişi
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="staff-badge empty">
                                            <i class="bi bi-person-dash"></i> Personel yok
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/Admin/Unit/UnitUsers/@item.Id" class="btn btn-action btn-view">
                                        <i class="bi bi-eye"></i> İncele
                                    </a>
                                    <a href="/Admin/Unit/UpdateUnit/@item.Id" class="btn btn-action btn-edit">
                                        <i class="bi bi-pencil-square"></i> Düzenle
                                    </a>
                                    <button onclick="deleteUnit(@item.Id, '@item.Ad', @item.PersonellerCount)" class="btn btn-action btn-delete">
                                        <i class="bi bi-trash3"></i> Sil
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="bi bi-diagram-3"></i>
                                    <p>Henüz kayıtlı birim bulunmuyor.</p>
                                    <a class="btn btn-add" href="/Admin/Unit/CreateUnit">
                                        <i class="bi bi-plus-lg me-1"></i> İlk Birimi Ekle
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function deleteUnit(id, name, staffCount) {
        let warningText = `<b>${name}</b> birimini silmek üzeresiniz.<br>Bu işlem geri alınamaz!`;
        if (staffCount > 0) {
            warningText = `<b>${name}</b> biriminde <b>${staffCount} personel</b> kayıtlı!<br>Silmek üzeresiniz, bu işlem geri alınamaz!`;
        }
        Swal.fire({
            title: "Emin misiniz?",
            html: warningText,
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#dc2626",
            cancelButtonColor: "#6c757d",
            confirmButtonText: '<i class="bi bi-trash3 me-1"></i> Evet, sil',
            cancelButtonText: "İptal",
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/Unit/DeleteUnit/" + id;
            }
        });
    }

    // İstemci tarafı arama (birim adı + departman adı)
    document.getElementById("unitSearch")?.addEventListener("input", function () {
        const term = this.value.toLowerCase().trim();
        document.querySelectorAll("#unitTable tbody tr").forEach(row => {
            if (row.querySelector(".empty-state")) return;
            row.style.display = row.textContent.toLowerCase().includes(term) ? "" : "none";
        });
    });
</script>
