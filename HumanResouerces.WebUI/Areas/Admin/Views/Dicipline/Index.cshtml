@model List<HumanResources.WebUI.DTOs.DiciplineDtos.ResultDiciplineDto>
@{
    ViewData["Title"] = "Disiplin ve Ödül Kayıtları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;

    // "Ödül" geçen kayıtları yeşil, diğerlerini (disiplin) kırmızı rozetle göstereceğiz
    bool IsOdul(string neden) => neden?.Contains("ödül", StringComparison.OrdinalIgnoreCase) == true
                              || neden?.Contains("odul", StringComparison.OrdinalIgnoreCase) == true;
}

<style>
    .dsp-card {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 1px 3px rgba(0,0,0,.04);
    }

    .dsp-header {
        padding: 1.25rem 1.5rem;
        background: #fff;
        border-bottom: 1px solid #f1f5f9;
    }

    .dsp-title {
        font-weight: 700;
        color: #111827;
        display: flex;
        align-items: center;
        gap: .75rem;
        margin: 0;
    }

        .dsp-title .icon-wrap {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0d9488, #0f766e);
            color: #fff;
            font-size: 1.15rem;
        }

    .dsp-subtitle {
        display: block;
        font-size: .82rem;
        font-weight: 400;
        color: #6b7280;
        margin-top: 2px;
    }

    .btn-add {
        background: linear-gradient(135deg, #0d9488, #0f766e);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: .55rem 1.1rem;
        font-weight: 600;
    }

        .btn-add:hover {
            color: #fff;
            filter: brightness(1.08);
        }

    .table-dsp {
        margin: 0;
    }

        .table-dsp thead th {
            background: #f8fafc;
            color: #64748b;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .04em;
            border-bottom: 1px solid #e5e7eb;
            padding: .85rem 1rem;
        }

        .table-dsp tbody td {
            padding: .9rem 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }

        .table-dsp tbody tr:hover {
            background: #f8fafc;
        }

    .row-index {
        color: #94a3b8;
        font-weight: 600;
        font-size: .85rem;
    }

    .record-name {
        font-weight: 600;
        color: #1f2937;
    }

    .type-badge {
        font-size: .74rem;
        font-weight: 700;
        padding: .3rem .65rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
    }

        .type-badge.odul {
            background: #ecfdf5;
            color: #059669;
        }

        .type-badge.ceza {
            background: #fef2f2;
            color: #dc2626;
        }

    .date-badge {
        background: #f1f5f9;
        color: #475569;
        font-size: .78rem;
        padding: .3rem .6rem;
        border-radius: 8px;
    }

    .doc-badge {
        font-size: .76rem;
        padding: .3rem .6rem;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        margin-right: .25rem;
    }

        .doc-badge.var {
            background: #eff6ff;
            color: #2563eb;
        }

        .doc-badge.ispat {
            background: #f0fdfa;
            color: #0d9488;
        }

        .doc-badge.yok {
            background: #f8fafc;
            color: #94a3b8;
        }

    .btn-action {
        border: none;
        border-radius: 8px;
        font-size: .8rem;
        font-weight: 600;
        padding: .4rem .75rem;
        transition: .15s;
    }

    .btn-details {
        background: #fdf4ff;
        color: #c026d3;
    }

        .btn-details:hover {
            background: #fae8ff;
            color: #a21caf;
        }

    .btn-edit {
        background: #eef2ff;
        color: #4f46e5;
    }

        .btn-edit:hover {
            background: #e0e7ff;
            color: #4338ca;
        }

    .btn-delete {
        background: #fef2f2;
        color: #dc2626;
    }

        .btn-delete:hover {
            background: #fee2e2;
            color: #b91c1c;
        }

    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: #94a3b8;
    }

        .empty-state i {
            font-size: 2.5rem;
            display: block;
            margin-bottom: .75rem;
        }
</style>

<div class="card dsp-card mb-4">
    <div class="dsp-header d-flex flex-wrap justify-content-between align-items-center gap-3">
        <h5 class="dsp-title">
            <span class="icon-wrap"><i class="bi bi-file-earmark-person"></i></span>
            <span>
                Disiplin ve Ödül Kayıtları
                <span class="dsp-subtitle">Personellerin ceza, tutanak ve ödül süreçlerini yönetin</span>
            </span>
        </h5>
        <a class="btn btn-add" href="/Admin/Dicipline/CreateDicipline">
            <i class="bi bi-plus-lg me-1"></i> Yeni Kayıt
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dsp">
                <thead>
                    <tr>
                        <th style="width:5%">#</th>
                        <th style="width:10%">Tür</th>
                        <th style="width:14%">Personel</th>
                        <th style="width:26%">Kayıt Nedeni</th>
                        <th style="width:13%">Olay Tarihi</th>
                        <th style="width:16%">Ekler</th>
                        <th style="width:30%" class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model.OrderByDescending(x => x.OlayTarihi))
                        {
                            count++;
                            var odul = IsOdul(item.DisiplinNedeni);
                            <tr>
                                <td><span class="row-index">@count</span></td>
                                <td>
                                    <span class="type-badge @(odul ? "odul" : "ceza")">
                                        <i class="bi @(odul ? "bi-trophy" : "bi-exclamation-triangle")"></i>
                                        @(odul ? "Ödül" : "Disiplin")
                                    </span>
                                </td>
                                <td class="fw-semibold text-nowrap">@item.AppUser?.Ad @item.AppUser?.Soyad</td>
                                <td><span class="record-name">@item.DisiplinNedeni</span></td>
                                <td><span class="date-badge"><i class="bi bi-calendar3 me-1"></i>@item.OlayTarihi.ToString("dd.MM.yyyy")</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.DosyaYolu))
                                    {
                                        <span class="doc-badge var"><i class="bi bi-paperclip"></i> Belge</span>
                                    }
                                    @if (!string.IsNullOrEmpty(item.IspatGorseliYolu))
                                    {
                                        <span class="doc-badge ispat"><i class="bi bi-camera"></i> İspat</span>
                                    }
                                    @if (string.IsNullOrEmpty(item.DosyaYolu) && string.IsNullOrEmpty(item.IspatGorseliYolu))
                                    {
                                        <span class="doc-badge yok"><i class="bi bi-dash-lg"></i> Yok</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/Admin/Dicipline/DiciplineDetails?id=@item.Id&userId=@item.AppUserId" class="btn btn-action btn-details">
                                        <i class="bi bi-search"></i> İncele
                                    </a>
                                    <a href="/Admin/Dicipline/UpdateDicipline/@item.Id" class="btn btn-action btn-edit">
                                        <i class="bi bi-pencil-square"></i> Düzenle
                                    </a>
                                    <button onclick="deleteDicipline(@item.Id, '@item.DisiplinNedeni')" class="btn btn-action btn-delete">
                                        <i class="bi bi-trash3"></i> Sil
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <i class="bi bi-file-earmark-x"></i>
                                    <p class="mb-2">Henüz disiplin veya ödül kaydı bulunmuyor.</p>
                                    <a href="/Admin/Dicipline/CreateDicipline" class="btn btn-add btn-sm">İlk kaydı oluştur</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function deleteDicipline(id, name) {
        Swal.fire({
            title: "Emin misiniz?",
            html: `<b>${name}</b> kaydını silmek üzeresiniz.<br>Ekli belgeler de sunucudan silinecek. Bu işlem geri alınamaz!`,
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#dc2626",
            cancelButtonColor: "#6c757d",
            confirmButtonText: '<i class="bi bi-trash3 me-1"></i> Evet, sil',
            cancelButtonText: "İptal",
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/Dicipline/DeleteDicipline/" + id;
            }
        });
    }

    // Controller'daki TempData mesajlarını toast olarak göster
    @if (TempData["Success"] != null)
    {
            <text>
            Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: '@TempData["Success"]', showConfirmButton: false, timer: 2500 });
            </text>
    }
    @if (TempData["Error"] != null)
    {
            <text>
            Swal.fire({ toast: true, position: 'top-end', icon: 'error', title: '@TempData["Error"]', showConfirmButton: false, timer: 3000 });
            </text>
    }
</script>