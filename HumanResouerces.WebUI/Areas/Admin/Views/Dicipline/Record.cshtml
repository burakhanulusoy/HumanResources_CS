@model HumanResources.WebUI.DTOs.DiciplineDtos.DiciplineDto
@{
    ViewData["Title"] = "Tutanak";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var u = Model.AppUser;
}

<style>
    .tutanak-sayfa {
        background: #fff;
        max-width: 800px;
        margin: 0 auto;
        padding: 3rem 3.5rem;
        border: 1px solid #e5e7eb;
        font-family: "Times New Roman", serif;
        font-size: 14px;
        line-height: 1.8;
        color: #111;
    }

    .tutanak-baslik {
        text-align: center;
        font-weight: 700;
        font-size: 18px;
        letter-spacing: 4px;
        margin-bottom: 2rem;
    }

    .tutanak-bolum {
        font-weight: 700;
        margin-top: 1.2rem;
    }

    .doldur {
        border-bottom: 1px dotted #555;
        padding: 0 6px;
        font-weight: 600;
    }

    .bos-satir {
        display: inline-block;
        min-width: 220px;
        border-bottom: 1px dotted #555;
    }

    .imza-alani {
        display: flex;
        justify-content: space-between;
        margin-top: 3rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .imza-kutu {
        min-width: 200px;
    }

        .imza-kutu .rol {
            font-weight: 700;
            margin-bottom: 2.2rem;
        }

    @@media print {
        body * {
            visibility: hidden;
        }

        .tutanak-sayfa, .tutanak-sayfa * {
            visibility: visible;
        }

        .tutanak-sayfa {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            border: none;
            padding: 1.5rem;
        }
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3" style="max-width:800px;margin:0 auto;">
    <a asp-action="DiciplineDetails" asp-route-id="@Model.Id" asp-route-userId="@Model.AppUserId"
       class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Detaya Dön</a>
    <button onclick="window.print()" class="btn btn-primary btn-sm"><i class="bi bi-printer me-1"></i> Yazdır</button>
</div>

<div class="tutanak-sayfa">
    <div class="tutanak-baslik">TUTANAK</div>

    <div class="tutanak-bolum">İŞVERENİN</div>
    <div>Unvanı: <span class="bos-satir"></span></div>

    <div class="tutanak-bolum">İŞÇİNİN</div>
    <div>Adı Soyadı: <span class="doldur">@u?.Ad @u?.Soyad</span></div>
    <div>T.C. Kimlik No: <span class="doldur">@u?.TcKimlikNo</span></div>
    <div>Bölümü: <span class="doldur">@u?.DepartmanAd@(!string.IsNullOrEmpty(u?.DepartmanAd) && !string.IsNullOrEmpty(u?.BirimAd) ? " / " : "")@u?.BirimAd</span></div>    <div>Görevi: <span class="doldur">@u?.PersonelTipi</span></div>

    <div class="tutanak-bolum">TESPİT EDİLEN DURUM / OLAYIN KONUSU</div>
    <p class="mt-2">
        <span class="doldur">@Model.OlayTarihi.ToString("dd/MM/yyyy")</span> tarihinde, yukarıda bilgileri yazılı personelin
        fabrikanın <span class="doldur">@u?.BirimAd</span> bölümündeki çalışması/vardiyası esnasında;
    </p>

    <p><strong>Kayıt Nedeni:</strong> <span class="doldur">@Model.DisiplinNedeni</span></p>

    <p>
        İşçinin, işyerinde uygulanmakta olan çalışma kurallarına ve iş disiplinine aykırı olarak
        aşağıda belirtilen eylemde/harekette bulunduğu tespit edilmiştir:
    </p>
    <p style="white-space: pre-line; border: 1px dotted #999; padding: .75rem; min-height: 90px;">@Model.Detay</p>

    <p>
        Yukarıda detayları belirtilen durum ile ilgili personelin işyerinde uygulanmakta olan çalışma kurallarına,
        fabrika düzenine ve iş disiplinine aykırı davrandığı ortaklaşa imza altına alınmıştır.
    </p>
    <p>
        İşbu tespit tutanağı aşağıdaki imzası bulunan kişiler huzurunda bir baskıya maruz kalmadan imzalanmıştır.
        &nbsp;&nbsp;<span class="doldur">@DateTime.Today.ToString("dd/MM/yyyy")</span>
    </p>

    <div class="imza-alani">
        <div class="imza-kutu">
            <div class="rol">VARDİYA AMİRİ</div>
            <div>Adı Soyadı: <span class="bos-satir" style="min-width:130px;"></span></div>
            <div class="mt-3">İmza:</div>
        </div>

        <div class="imza-kutu">
            <div class="rol">TANIKLAR</div>
            <div>
                Adı Soyadı:
                <span class="@(string.IsNullOrEmpty(Model.TanikAdSoyad) ? "bos-satir" : "doldur")" style="min-width:130px;">@Model.TanikAdSoyad</span>
            </div>
            <div class="mt-2 mb-3">İmza:</div>
            <div>Adı Soyadı: <span class="bos-satir" style="min-width:130px;"></span></div>
            <div class="mt-2">İmza:</div>
        </div>

        <div class="imza-kutu">
            <div class="rol">İŞÇİ</div>
            <div>Adı Soyadı: <span class="doldur">@u?.Ad @u?.Soyad</span></div>
            <div class="mt-3">İmza:</div>
        </div>
    </div>
</div>