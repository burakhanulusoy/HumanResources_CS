@model HumanResouerces.WebUI.Models.DiciplineUpdateViewModel
@{
    ViewData["Title"] = "Kayıt Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .dsp-form-card {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        box-shadow: 0 1px 3px rgba(0,0,0,.04);
        max-width: 860px;
        margin: 0 auto;
    }

    .dsp-form-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem 1.75rem;
        border-bottom: 1px solid #f1f5f9;
    }

        .dsp-form-header .icon-wrap {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #4f46e5, #4338ca);
            color: #fff;
            font-size: 1.3rem;
        }

    .dsp-form-title {
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .dsp-form-subtitle {
        color: #6b7280;
        font-size: .85rem;
        margin: 2px 0 0;
    }

    .dsp-form-body {
        padding: 1.75rem;
    }

    .dsp-label {
        font-weight: 600;
        color: #374151;
        font-size: .88rem;
        margin-bottom: .45rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .dsp-label i {
            color: #4f46e5;
        }

    .dsp-input {
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        padding: .6rem .85rem;
        font-size: .92rem;
    }

        .dsp-input:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79,70,229,.12);
        }

    .file-drop {
        border: 2px dashed #d1d5db;
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        color: #9ca3af;
        cursor: pointer;
        transition: .2s;
        background: #fafafa;
    }

        .file-drop:hover, .file-drop.has-file {
            border-color: #4f46e5;
            color: #4f46e5;
            background: #eef2ff;
        }

        .file-drop i {
            font-size: 1.6rem;
            display: block;
            margin-bottom: .35rem;
        }

        .file-drop input[type=file] {
            display: none;
        }

    .file-name {
        font-weight: 600;
        font-size: .88rem;
    }

    .current-file {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: .6rem .9rem;
        font-size: .85rem;
        color: #475569;
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .6rem;
    }

    .btn-update {
        background: linear-gradient(135deg, #4f46e5, #4338ca);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: .6rem 1.4rem;
        font-weight: 600;
    }

        .btn-update:hover {
            color: #fff;
            filter: brightness(1.1);
        }

    .btn-cancel {
        background: #f1f5f9;
        color: #475569;
        border: none;
        border-radius: 10px;
        padding: .6rem 1.2rem;
        font-weight: 600;
    }

        .btn-cancel:hover {
            background: #e2e8f0;
            color: #334155;
        }
</style>

<div class="card dsp-form-card mb-4">
    <div class="dsp-form-header">
        <span class="icon-wrap"><i class="bi bi-pencil-square"></i></span>
        <div>
            <h5 class="dsp-form-title">Kaydı Güncelle</h5>
            <p class="dsp-form-subtitle">Disiplin veya ödül kaydı detaylarını düzenleyin</p>
        </div>
    </div>
    <div class="card-body dsp-form-body">
        <form asp-action="UpdateDicipline" method="post" id="updateForm" enctype="multipart/form-data" novalidate>
            <input type="hidden" asp-for="Record.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label class="dsp-label"><i class="bi bi-person-badge"></i> Personel</label>
                    <select asp-for="Record.AppUserId" asp-items="Model.Users" class="form-select dsp-input" required></select>
                    <span class="text-danger small" asp-validation-for="Record.AppUserId"></span>
                </div>
                <div class="col-md-6 mb-4">
                    <label class="dsp-label"><i class="bi bi-calendar-event"></i> Olay Tarihi</label>
                    <input type="date" asp-for="Record.OlayTarihi" asp-format="{0:yyyy-MM-dd}" class="form-control dsp-input"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    <span class="text-danger small" asp-validation-for="Record.OlayTarihi"></span>
                </div>
            </div>

            <div class="mb-4">
                <label class="dsp-label"><i class="bi bi-card-text"></i> Kayıt Nedeni</label>
                <input type="text" asp-for="Record.DisiplinNedeni" class="form-control dsp-input" maxlength="150" required />
                <span class="text-danger small" asp-validation-for="Record.DisiplinNedeni"></span>
            </div>

            <div class="mb-4">
                <label class="dsp-label"><i class="bi bi-person-check"></i> Tanık Adı Soyadı (Opsiyonel)</label>
                <input type="text" asp-for="Record.TanikAdSoyad" class="form-control dsp-input" maxlength="100" />
                <span class="text-danger small" asp-validation-for="Record.TanikAdSoyad"></span>
            </div>

            <div class="mb-4">
                <label class="dsp-label"><i class="bi bi-justify-left"></i> Detaylı Açıklama</label>
                <textarea asp-for="Record.Detay" class="form-control dsp-input" rows="4" maxlength="1500" required></textarea>
                <span class="text-danger small" asp-validation-for="Record.Detay"></span>
            </div>

            <div class="mb-4">
                <label class="dsp-label"><i class="bi bi-paperclip"></i> Belge / Savunma</label>

                @if (!string.IsNullOrEmpty(Model.MevcutDosyaYolu))
                {
                    <div class="current-file">
                        <i class="bi bi-file-earmark-check text-success"></i>
                        Mevcut belge var —
                        <a href="@Model.MevcutDosyaYolu" target="_blank">görüntüle</a>.
                        Yeni dosya yüklerseniz eskisi silinir.
                    </div>
                }

                <label class="file-drop d-block" id="fileDrop">
                    <i class="bi bi-cloud-arrow-up"></i>
                    <span class="file-name" id="fileName">Yeni belge yüklemek için tıklayın (değiştirmek istemiyorsanız boş bırakın)</span>
                    <input type="file" asp-for="Record.Dosya" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.xlsx" />
                </label>
                <span class="text-danger small" asp-validation-for="Record.Dosya"></span>
            </div>

            <div class="mb-4">
                <label class="dsp-label"><i class="bi bi-camera"></i> İspat Görseli</label>
                <label class="file-drop d-block" id="ispatDrop">
                    <i class="bi bi-image"></i>
                    <span class="file-name" id="ispatName">Yeni görsel yüklemek için tıklayın (değiştirmek istemiyorsanız boş bırakın)</span>
                    <input type="file" asp-for="Record.IspatGorseli" accept=".jpg,.jpeg,.png" />
                </label>
                <span class="text-danger small" asp-validation-for="Record.IspatGorseli"></span>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a href="/Admin/Dicipline/Index" class="btn btn-cancel">İptal</a>
                <button type="submit" class="btn btn-update"><i class="bi bi-check-lg"></i> Güncelle</button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const fileInput = document.querySelector('#fileDrop input[type=file]');
    fileInput.addEventListener('change', function () {
        if (this.files.length > 0) {
            document.getElementById('fileName').textContent = this.files[0].name;
            document.getElementById('fileDrop').classList.add('has-file');
        }
    });

    const ispatInput = document.querySelector('#ispatDrop input[type=file]');
    ispatInput.addEventListener('change', function () {
        if (this.files.length > 0) {
            document.getElementById('ispatName').textContent = this.files[0].name;
            document.getElementById('ispatDrop').classList.add('has-file');
        }
    });

    document.getElementById('updateForm').addEventListener('submit', function (e) {
        var form = this;
        if (!form.checkValidity()) { form.reportValidity(); e.preventDefault(); return; }
        e.preventDefault();
        Swal.fire({
            title: "Emin misiniz?",
            text: "Kayıt bilgileri güncellenecektir.",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#4f46e5",
            cancelButtonColor: "#6c757d",
            confirmButtonText: "Evet, güncelle",
            cancelButtonText: "İptal",
            reverseButtons: true
        }).then(res => { if (res.isConfirmed) form.submit(); });
    });
</script>