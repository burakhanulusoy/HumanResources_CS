@model List<HumanResources.WebUI.DTOs.ShiftDtos.ResultShiftDto>
@{
    ViewData["Title"] = "Aktif Vardiya Atamaları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string pdfFileName = $"Vardiya_Listesi_Raporu_{DateTime.Now.ToString("dd_MM_yyyy")}.pdf";
    int totalStaff = Model?.Sum(s => s.Personeller?.Count ?? 0) ?? 0;
}

<style>
    .toolbar {
        background: #fff;
        border: 1px solid #eef0f3;
        border-radius: 14px;
        padding: 14px 20px;
    }

    .btn-outline-back {
        background: #f3f4f6;
        color: #4b5563;
        border: 1px solid #e5e7eb;
        font-weight: 500;
        border-radius: 10px;
    }

        .btn-outline-back:hover {
            background: #e5e7eb;
            color: #1f2937;
        }

    .btn-download-pdf {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        border: none;
        color: #fff;
        font-weight: 600;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(220,38,38,.25);
    }

        .btn-download-pdf:hover {
            filter: brightness(1.05);
            color: #fff;
        }

    /* ===== Resmi belge şablonu ===== */
    #pdfContent {
        background: #ffffff;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #1a1a1a;
        border-radius: 4px;
    }

    .doc-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        border-bottom: 3px double #000;
        padding-bottom: 14px;
        margin-bottom: 18px;
    }

        .doc-header .org-info h3 {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .02em;
        }

        .doc-header .org-info p {
            margin: 2px 0 0;
            font-size: .78rem;
            color: #444;
        }

        .doc-header .doc-meta {
            text-align: right;
            font-size: .78rem;
            color: #333;
            line-height: 1.6;
        }

            .doc-header .doc-meta strong {
                color: #000;
            }

    .doc-title {
        text-align: center;
        margin-bottom: 20px;
    }

        .doc-title h2 {
            font-size: 1.15rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .03em;
            margin: 0;
            text-decoration: underline;
        }

        .doc-title p {
            margin: 4px 0 0;
            font-size: .78rem;
            color: #444;
        }

    .doc-info-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 26px;
        font-size: .85rem;
    }

        .doc-info-table td {
            border: 1px solid #000;
            padding: 8px 12px;
        }

            .doc-info-table td.label {
                background: #f0f0f0;
                font-weight: 700;
                width: 22%;
            }

    .doc-shift-block {
        margin-bottom: 26px;
    }

    .doc-shift-heading {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #000;
        background: #e5e5e5;
        padding: 8px 12px;
        font-size: .85rem;
        font-weight: 700;
    }

    .doc-staff-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
    }

        .doc-staff-table th {
            border: 1px solid #000;
            border-top: none;
            background: #f0f0f0;
            padding: 8px 10px;
            font-weight: 700;
            text-transform: uppercase;
            font-size: .74rem;
            text-align: left;
        }

        .doc-staff-table td {
            border: 1px solid #000;
            border-top: none;
            padding: 8px 10px;
        }

        .doc-staff-table tbody tr:nth-child(even) {
            background: #fafafa;
        }

        .doc-staff-table .empty-row td {
            text-align: center;
            font-style: italic;
            color: #555;
        }

    .doc-signature-area {
        display: flex;
        justify-content: space-between;
        margin-top: 50px;
    }

    .doc-signature-box {
        width: 30%;
        text-align: center;
        font-size: .8rem;
    }

    .doc-signature-line {
        border-top: 1px solid #000;
        margin-top: 50px;
        padding-top: 6px;
    }

    .doc-footer {
        margin-top: 25px;
        border-top: 1px solid #000;
        padding-top: 10px;
        font-size: .7rem;
        color: #444;
        display: flex;
        justify-content: space-between;
    }
</style>

<div class="toolbar d-flex justify-content-between align-items-center mb-4">
    <a href="/Admin/Shift/Index" class="btn btn-outline-back px-3">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" /></svg>
        Geri Dön
    </a>
    <button id="downloadPdfBtn" class="btn btn-download-pdf px-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
        Tüm Listeyi PDF İndir
    </button>
</div>

<div id="pdfContent" class="card shadow-sm p-5">

    <div class="doc-header">
        <div class="org-info">
            <h3>İnsan Kaynakları Departmanı</h3>
            <p>Vardiya Yönetim Sistemi</p>
        </div>
        <div class="doc-meta">
            <div><strong>Rapor No:</strong> VRD-@DateTime.Now.ToString("yyyyMMdd")</div>
            <div><strong>Düzenleme Tarihi:</strong> @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</div>
            <div><strong>Durum:</strong> Onaylı</div>
        </div>
    </div>

    <div class="doc-title">
        <h2>Aktif Vardiya Şablonları ve Personel Atama Raporu</h2>
        <p>Kurum İçi Personel Dağılım Belgesi</p>
    </div>

    <table class="doc-info-table">
        <tr>
            <td class="label">Toplam Vardiya</td>
            <td>@(Model?.Count ?? 0)</td>
            <td class="label">Toplam Atanan Personel</td>
            <td>@totalStaff Kişi</td>
        </tr>
        <tr>
            <td class="label">Rapor Tarihi</td>
            <td colspan="3">@DateTime.Now.ToString("dd.MM.yyyy")</td>
        </tr>
    </table>

    @if (Model != null && Model.Any())
    {
        foreach (var shift in Model)
        {
            <div class="doc-shift-block">
                <div class="doc-shift-heading">
                    <span>@shift.Aciklama</span>
                    <span>@shift.BaslangicSaati.ToString(@"hh\:mm") - @shift.BitisSaati.ToString(@"hh\:mm") &nbsp;|&nbsp; Mola: @shift.AraDinlenmeSuresiDk dk</span>
                </div>

                <table class="doc-staff-table">
                    <thead>
                        <tr>
                            <th style="width: 8%;">#</th>
                            <th style="width: 46%;">Personel Adı Soyadı</th>
                            <th style="width: 46%;">Sicil No / E-Posta</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (shift.Personeller != null && shift.Personeller.Any())
                        {
                            int pCount = 0;
                            foreach (var p in shift.Personeller)
                            {
                                pCount++;
                                <tr>
                                    <td>@pCount</td>
                                    <td>@p.Ad @p.Soyad</td>
                                    <td>@(string.IsNullOrEmpty(p.SicilNo) ? p.Email : p.SicilNo)</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr class="empty-row">
                                <td colspan="3">Bu vardiyaya atanmış personel bulunmamaktadır.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <div class="alert alert-warning text-center">Aktif vardiya şablonu bulunamadı.</div>
    }

    <div class="doc-signature-area">
        <div class="doc-signature-box"><div class="doc-signature-line">İnsan Kaynakları Yetkilisi</div></div>
        <div class="doc-signature-box"><div class="doc-signature-line">Departman Sorumlusu</div></div>
        <div class="doc-signature-box"><div class="doc-signature-line">Genel Müdür Onayı</div></div>
    </div>

    <div class="doc-footer">
        <span>Bu rapor sistemdeki güncel verilere göre otomatik oluşturulmuştur.</span>
        <span>Sayfa 1/1</span>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    document.getElementById('downloadPdfBtn').addEventListener('click', function () {
        var element = document.getElementById('pdfContent');
        var opt = {
            margin: 0.5,
            filename: '@pdfFileName',
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2 },
            jsPDF: { unit: 'in', format: 'A4', orientation: 'portrait' }
        };
        html2pdf().set(opt).from(element).save();
    });
</script>