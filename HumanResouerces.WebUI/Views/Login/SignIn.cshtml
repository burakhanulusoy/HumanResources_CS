                    </button>
                </form>
                <!-- Links -->
                <div class="flex justify-between items-center pt-8 mt-4 border-t border-white/5">
                    <a class="font-label-sm text-[11px] text-on-surface-variant/60 hover:text-tertiary transition-colors flex items-center gap-2 uppercase tracking-wider" href="#">
