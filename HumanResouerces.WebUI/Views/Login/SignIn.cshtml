            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-[1px] bg-tertiary/30"></div>
            <div class="flex flex-col md:flex-row justify-between w-full items-center gap-6 max-w-container-max mx-auto">
                <span class="font-label-sm text-[10px] text-on-surface-variant/50 text-center md:text-left tracking-[0.15em] uppercase">
                    © 2024 DEFENSE SYSTEMS OPERATIONAL COMMAND. ALL RIGHTS RESERVED. SENSITIVE COMPARTMENTED INFORMATION.
                </span>
                <nav class="flex gap-8 flex-wrap justify-center">
                    <a class="font-label-sm text-[10px] text-on-surface-variant/40 hover:text-tertiary transition-colors uppercase tracking-[0.2em]" href="#">Security Policy</a>
                    <a class="font-label-sm text-[10px] text-on-surface-variant/40 hover:text-tertiary transition-colors uppercase tracking-[0.2em]" href="#">Terms of Service</a>
                    <a class="font-label-sm text-[10px] text-on-surface-variant/40 hover:text-tertiary transition-colors uppercase tracking-[0.2em]" href="#">Contact Support</a>
