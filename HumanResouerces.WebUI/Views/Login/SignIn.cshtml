                        <label class="font-label-sm text-[11px] text-tertiary/60 uppercase tracking-[0.2em]" for="password">Şifre</label>
                        <div class="relative input-glow border border-white/5 rounded-lg bg-black/20 transition-all duration-300 flex items-center group">
