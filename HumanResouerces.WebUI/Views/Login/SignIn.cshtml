                    <div class="w-12 h-0.5 bg-tertiary/40 my-2 mx-auto"></div>
                    <p class="font-body-md text-body-sm text-on-surface-variant/80 tracking-widest uppercase">Sisteme erişmek için kimlik bilgilerinizi doğrulayın.</p>
                </div>
                <!-- Login Form -->
                <form class="flex flex-col gap-stack-md mt-4" onsubmit="event.preventDefault();">
                    <!-- Username -->
                    <div class="flex flex-col gap-stack-xs">
                        <label class="font-label-sm text-[11px] text-tertiary/60 uppercase tracking-[0.2em]" for="username">Kullanıcı Adı</label>
                        <div class="relative input-glow border border-white/5 rounded-lg bg-black/20 transition-all duration-300 flex items-center group">
                            <span class="material-symbols-outlined absolute left-4 text-on-surface-variant/50 text-[18px] group-focus-within:text-tertiary transition-colors" data-icon="shield_person">shield_person</span>
                            <input class="w-full bg-transparent border-none focus:ring-0 text-on-surface font-body-md text-body-md py-4 pl-12 pr-4 placeholder:text-outline/40 placeholder:font-light" id="username" placeholder="Sicil No / Kimlik" type="text" />
                        </div>
                    </div>
                    <!-- Password -->
