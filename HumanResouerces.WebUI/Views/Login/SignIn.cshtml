                                <span class="material-symbols-outlined text-[18px]" data-icon="visibility">visibility</span>
                            </button>
                        </div>
                    </div>
                    <!-- Action Button -->
                    <button class="mt-6 w-full bg-primary-container/40 hover:bg-primary-container/80 border border-tertiary/20 hover:border-tertiary/60 text-primary font-label-lg text-label-lg uppercase py-4 rounded-lg transition-all duration-500 relative overflow-hidden group shadow-[0_0_20px_rgba(0,0,0,0.3)]" type="submit">
