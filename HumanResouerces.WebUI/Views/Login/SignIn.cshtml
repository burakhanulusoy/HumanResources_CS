                <!-- Top Highlight -->
                <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-tertiary/60 to-transparent"></div>
                <!-- Branding -->
                <div class="flex flex-col items-center justify-center gap-stack-sm text-center">
                    <div class="bg-white/5 p-1 rounded-full border border-white/10 mb-4 ring-8 ring-white/5">
                        <img alt="CS SAVUNMA Logo" class="w-16 h-16 object-contain brightness-110" src="https://lh3.googleusercontent.com/aida/AP1WRLtl8SV0luqmaEXCVr7QHCN4pN12w_qP8YvHARZaI1Pj1nYOh7fsutPk_4Y995KOe4aYeeNaZzZmnQl8NFkULts1lYT7a3Noiws_gdRRVp6mqUbmu95nAMJwUSU2AuisJe3QufYbWSJZUDTXbqTRdagEQyyM23Ke0P1ff3dc7AqRmiltsGzxAViddhieDBBU-m0yHj7Z1mWMsYDS8b96_TohqmxD1_fW2kBArYTQNMu5AasEGttXi_vvyJY" />
                    </div>
